# ============================================================
# Cazador de Tendencias — Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena los valores con tus tokens reales.
# cp .env.example .env
#
# ⚠️  NUNCA subas el archivo .env a tu repositorio.
#     Asegúrate de que .env esté en tu .gitignore.
# ============================================================

# ----------------------------------------------------------
# FASE 1: Extracción — Apify
# ----------------------------------------------------------
# Regístrate gratis en https://console.apify.com/sign-up
# Tu token se encuentra en: Settings → Integrations → API token
APIFY_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID del actor de TikTok Scraper en Apify (por defecto: clockworks/tiktok-scraper)
APIFY_TIKTOK_ACTOR_ID=clockworks/tiktok-scraper

# ----------------------------------------------------------
# FASE 2: Filtrado — Google Trends (Pytrends)
# ----------------------------------------------------------
# Pytrends no requiere API key. Usa la API pública de Google Trends.
# Opcional: puedes configurar un proxy si Google bloquea tus peticiones.
# Formato: https://usuario:password@host:puerto
PYTRENDS_PROXY=

# ----------------------------------------------------------
# FASE 3: Validación — RapidAPI (AliExpress)
# ----------------------------------------------------------
# Regístrate gratis en https://rapidapi.com/
# Suscríbete al plan gratuito de "AliExpress Data" API
# Tu clave se encuentra en: Dashboard → My Apps → Default Application → Security
RAPIDAPI_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Host del endpoint de AliExpress en RapidAPI
RAPIDAPI_ALIEXPRESS_HOST=aliexpress-datahub.p.rapidapi.com

# ----------------------------------------------------------
# FASE 4: Alertas — Telegram Bot
# ----------------------------------------------------------
# 1. Habla con @BotFather en Telegram y usa /newbot para crear uno.
# 2. Copia el token que te entrega.
TELEGRAM_BOT_TOKEN=123456789:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ID del chat o canal donde se enviarán las alertas.
# Para obtenerlo: envía un mensaje a tu bot, luego visita:
# https://api.telegram.org/bot<TU_TOKEN>/getUpdates
# Busca el campo "chat" → "id"
TELEGRAM_CHAT_ID=-1001234567890

# ----------------------------------------------------------
# CONFIGURACIÓN GENERAL
# ----------------------------------------------------------
# Umbral mínimo de vistas para considerar un video como "viral"
MIN_VIEWS_THRESHOLD=500000

# Umbral mínimo de engagement (likes + shares) para pasar el filtro
MIN_ENGAGEMENT_THRESHOLD=10000

# Número máximo de resultados por búsqueda de hashtag en TikTok
TIKTOK_RESULTS_PER_PAGE=30

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
