<style>
  .account-page { padding: var(--spacing-xxl) 0; }

  .account-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-xl);
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }
  .account-header__welcome {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
  }
  .account-header__welcome span {
    background: var(--color-accent);
    color: var(--color-accent-ink);
    padding: 0 8px;
    border-radius: var(--radius-sm);
  }
  .account-logout {
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .account-logout:hover { color: var(--color-muted); }

  .account-grid { display: grid; grid-template-columns: 1fr; gap: var(--spacing-xl); }

  .account-orders__title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-line);
  }

  .orders-table { width: 100%; border-collapse: separate; border-spacing: 0; }
  .orders-table th {
    text-align: left;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--color-faint);
  }
  .orders-table td {
    padding: var(--spacing-md);
    border-bottom: 1px solid var(--color-line);
    font-size: 0.875rem;
  }
  .orders-table a { color: var(--color-text); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }

  .order-status {
    display: inline-block;
    padding: 3px var(--spacing-sm);
    border-radius: var(--radius-full);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .order-status--paid { background: rgba(31, 191, 107, 0.12); color: #178a4e; }
  .order-status--pending { background: rgba(10, 10, 11, 0.06); color: var(--color-muted); }
  .order-status--fulfilled { background: var(--color-accent-soft); color: #5b7a00; }

  .account-sidebar__card {
    background: var(--color-card-bg);
    padding: var(--spacing-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-line);
  }
  .account-sidebar__title {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }
  .account-sidebar__item { display: flex; gap: var(--spacing-sm); margin-bottom: var(--spacing-sm); font-size: 0.875rem; }
  .account-sidebar__label { font-weight: 600; min-width: 64px; color: var(--color-muted); }

  .account-empty { text-align: center; padding: var(--spacing-xxxl); color: var(--color-muted); }

  /* ── Responsive: card-based layout for mobile ── */
  .orders-mobile { display: none; }

  @media (min-width: 768px) {
    .account-grid { grid-template-columns: 2fr 1fr; }
  }
  @media (max-width: 767px) {
    .orders-table-wrap { display: none; }
    .orders-mobile { display: flex; flex-direction: column; gap: var(--spacing-md); }
    .orders-mobile__card {
      background: var(--color-card-bg);
      padding: var(--spacing-md);
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-line);
    }
    .orders-mobile__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--spacing-sm); }
    .orders-mobile__order-name a { color: var(--color-text); font-weight: 600; font-size: 0.875rem; text-decoration: underline; }
    .orders-mobile__row { display: flex; justify-content: space-between; font-size: 0.8125rem; padding: var(--spacing-xs) 0; color: var(--color-muted); }
    .orders-mobile__row strong { color: var(--color-text); }
  }
</style>

<div class="account-page container">
  {%- comment -%} ── Header ── {%- endcomment -%}
  <div class="account-header">
    <h1 class="account-header__welcome">
      Welcome back, <span>{{ customer.first_name | default: customer.name }}</span>!
    </h1>
    <a href="{{ routes.account_logout_url }}" class="account-logout">Log out</a>
  </div>

  <div class="account-grid">
    {%- comment -%} ── Orders Column ── {%- endcomment -%}
    <div class="account-orders">
      <h2 class="account-orders__title">Order History</h2>

      {% if customer.orders.size > 0 %}
        {%- comment -%} Desktop table {%- endcomment -%}
        <div class="orders-table-wrap">
          <table class="orders-table">
            <thead>
              <tr>
                <th>Order</th>
                <th>Date</th>
                <th>Payment</th>
                <th>Fulfillment</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              {% for order in customer.orders %}
                <tr>
                  <td>
                    <a href="{{ order.url }}">{{ order.name }}</a>
                  </td>
                  <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                  <td>
                    <span class="order-status
                      {%- if order.financial_status == 'paid' %} order-status--paid
                      {%- elsif order.financial_status == 'pending' %} order-status--pending
                      {%- else %} order-status--fulfilled
                      {%- endif -%}
                    ">
                      {{ order.financial_status }}
                    </span>
                  </td>
                  <td>
                    {% if order.fulfillment_status %}
                      <span class="order-status order-status--fulfilled">
                        {{ order.fulfillment_status }}
                      </span>
                    {% else %}
                      <span class="order-status order-status--pending">Unfulfilled</span>
                    {% endif %}
                  </td>
                  <td>{{ order.total_price | money }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {%- comment -%} Mobile card layout {%- endcomment -%}
        <div class="orders-mobile">
          {% for order in customer.orders %}
            <div class="orders-mobile__card">
              <div class="orders-mobile__header">
                <span class="orders-mobile__order-name">
                  <a href="{{ order.url }}">{{ order.name }}</a>
                </span>
                <span class="order-status
                  {%- if order.financial_status == 'paid' %} order-status--paid
                  {%- elsif order.financial_status == 'pending' %} order-status--pending
                  {%- else %} order-status--fulfilled
                  {%- endif -%}
                ">
                  {{ order.financial_status }}
                </span>
              </div>
              <div class="orders-mobile__row">
                <span>Date</span>
                <strong>{{ order.created_at | date: '%B %d, %Y' }}</strong>
              </div>
              <div class="orders-mobile__row">
                <span>Fulfillment</span>
                <strong>
                  {% if order.fulfillment_status %}
                    {{ order.fulfillment_status }}
                  {% else %}
                    Unfulfilled
                  {% endif %}
                </strong>
              </div>
              <div class="orders-mobile__row">
                <span>Total</span>
                <strong>{{ order.total_price | money }}</strong>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="account-empty">
          <p>You haven't placed any orders yet.</p>
        </div>
      {% endif %}
    </div>

    {%- comment -%} ── Sidebar ── {%- endcomment -%}
    <div class="account-sidebar">
      <div class="account-sidebar__card">
        <h3 class="account-sidebar__title">Account Details</h3>

        <div class="account-sidebar__item">
          <span class="account-sidebar__label">Email</span>
          <span>{{ customer.email }}</span>
        </div>

        <div class="account-sidebar__item">
          <span class="account-sidebar__label">Orders</span>
          <span>{{ customer.orders_count }}</span>
        </div>

        {% if customer.default_address %}
          <div class="account-sidebar__item">
            <span class="account-sidebar__label">Address</span>
            <span>
              {{ customer.default_address.city }}{% if customer.default_address.province %}, {{ customer.default_address.province }}{% endif %}, {{ customer.default_address.country }}
            </span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Account",
  "settings": [],
  "presets": [{ "name": "Customer Account" }]
}
{% endschema %}
