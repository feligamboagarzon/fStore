{% render 'customer-auth-styles' %}

<div class="auth-page container">
  <div class="auth-card">

    {%- comment -%} Login Form {%- endcomment -%}
    <div id="login-form">
      <div class="auth-card__header">
        <h1 class="auth-card__title">{{ section.settings.heading }}</h1>
        <p class="auth-card__subtitle">{{ section.settings.subheading }}</p>
      </div>

      {% form 'customer_login' %}
        {%- if form.errors -%}
          <ul class="auth-errors">
            {%- for field in form.errors -%}
              <li>{{ form.errors.translated_fields[field] }} — {{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="auth-form__group">
          <label class="auth-form__label" for="CustomerEmail">Email</label>
          <input
            class="auth-form__input"
            type="email"
            id="CustomerEmail"
            name="customer[email]"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
          >
        </div>

        <div class="auth-form__group">
          <label class="auth-form__label" for="CustomerPassword">Password</label>
          <input
            class="auth-form__input"
            type="password"
            id="CustomerPassword"
            name="customer[password]"
            autocomplete="current-password"
            required
          >
        </div>

        <div class="auth-form__group" style="text-align: right; margin-bottom: var(--spacing-sm);">
          <a
            href="#"
            class="auth-form__link"
            onclick="document.getElementById('recover-form').style.display='block'; document.getElementById('login-form').style.display='none'; return false;"
          >
            Forgot password?
          </a>
        </div>

        <button type="submit" class="auth-form__submit">Sign In</button>
      {% endform %}

      <div class="auth-divider">or</div>

      <div class="auth-form__footer">
        <p>Don't have an account? <a href="{{ routes.account_register_url }}" class="auth-form__link">Create one</a></p>
      </div>
    </div>

    {%- comment -%} Password Recovery Form {%- endcomment -%}
    <div id="recover-form" style="display: none;">
      <div class="auth-card__header">
        <h1 class="auth-card__title">Reset Password</h1>
        <p class="auth-card__subtitle">We'll send you an email to reset your password.</p>
      </div>

      {% form 'recover_customer_password' %}
        {%- if form.posted_successfully? -%}
          <ul class="auth-success">
            <li>We've sent you an email with a link to update your password.</li>
          </ul>
        {%- endif -%}

        <div class="auth-form__group">
          <label class="auth-form__label" for="RecoverEmail">Email</label>
          <input
            class="auth-form__input"
            type="email"
            id="RecoverEmail"
            name="email"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            required
          >
        </div>

        <button type="submit" class="auth-form__submit">Reset Password</button>
      {% endform %}

      <div class="auth-form__footer" style="margin-top: var(--spacing-lg);">
        <p>
          <a
            href="#"
            class="auth-form__link"
            onclick="document.getElementById('recover-form').style.display='none'; document.getElementById('login-form').style.display='block'; return false;"
          >
            ← Back to login
          </a>
        </p>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Customer Login",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome Back"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sign in to your account to track orders and manage your info."
    }
  ],
  "presets": [
    {
      "name": "Customer Login"
    }
  ]
}
{% endschema %}
