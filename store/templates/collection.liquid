{% layout 'checkout' %}
{% comment %} Fstore Colección — Claude Design recreated, real Shopify collection data. {% endcomment %}
<style>
  *{ box-sizing:border-box; }
  ::selection{ background:#c6ff3a; color:#0b0b0c; }
  @keyframes fs-marquee{ from{ transform:translateX(0); } to{ transform:translateX(-50%); } }
  @keyframes fs-pulse{ 0%,100%{ opacity:1; transform:scale(1); } 50%{ opacity:.35; transform:scale(.7); } }
  .fs{ background:#0b0b0c; color:#f5f5f4; font-family:'Space Grotesk',sans-serif; min-height:100vh; overflow-x:hidden; position:relative; }
  .fs a{ color:inherit; text-decoration:none; }
  .fs-w{ max-width:1200px; margin:0 auto; padding-left:clamp(16px,4vw,40px); padding-right:clamp(16px,4vw,40px); position:relative; z-index:1; }
  .fs-h{ font-family:'Archivo',sans-serif; font-weight:900; text-transform:uppercase; letter-spacing:-.025em; }
  .fs-nav a:hover{ color:#c6ff3a; }
  .fs-add:hover{ background:#d4ff5e; }
  .fs-pcard{ transition:border-color .18s, transform .18s; }
  .fs-pcard:hover{ border-color:#3a3a40; transform:translateY(-3px); }
  .fs-col-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(min(100%,210px),1fr)); gap:clamp(12px,2vw,18px); }
  .fs-scrollx{ overflow-x:auto; }
  .fs-scrollx::-webkit-scrollbar{ height:0; }
  .fs-tab:hover{ color:#f5f5f4; }
  .fs-pill:hover{ border-color:#c6ff3a; }
  .fs-heart:hover{ background:rgba(255,46,110,.22); border-color:#ff2e6e; }
  .fs-pg a:hover, .fs-pg .fs-pg-cur{ background:#1b1b1e; border-color:#c6ff3a; }
  .fs-sort:focus{ outline:none; border-color:#c6ff3a; }
  @media (prefers-reduced-motion: reduce){ .fs *{ animation-duration:.001ms !important; transition:none !important; } }
</style>

{%- comment -%} Per-collection fallback blurb/emoji keyed off handle/title {%- endcomment -%}
{%- assign chandle = collection.handle | downcase -%}
{%- assign ctitle = collection.title | downcase -%}
{%- assign banner_emoji = '🔥' -%}
{%- assign banner_blurb = 'collection.banner_blurb_trend' | t -%}
{%- if chandle contains 'gadget' or ctitle contains 'gadget' -%}
  {%- assign banner_emoji = '🔌' -%}{%- assign banner_blurb = 'collection.banner_blurb_gadget' | t -%}
{%- elsif chandle contains 'hogar' or ctitle contains 'hogar' or ctitle contains 'casa' -%}
  {%- assign banner_emoji = '🏠' -%}{%- assign banner_blurb = 'collection.banner_blurb_home' | t -%}
{%- elsif chandle contains 'belleza' or ctitle contains 'belleza' or ctitle contains 'beauty' -%}
  {%- assign banner_emoji = '💄' -%}{%- assign banner_blurb = 'collection.banner_blurb_beauty' | t -%}
{%- elsif chandle contains 'tech' or ctitle contains 'tech' or ctitle contains 'tecno' -%}
  {%- assign banner_emoji = '📱' -%}{%- assign banner_blurb = 'collection.banner_blurb_tech' | t -%}
{%- elsif chandle contains 'novedad' or ctitle contains 'novedad' or chandle contains 'nuevo' -%}
  {%- assign banner_emoji = '✨' -%}{%- assign banner_blurb = 'collection.banner_blurb_new' | t -%}
{%- elsif chandle contains 'trend' or ctitle contains 'trend' or chandle == 'frontpage' or chandle == 'all' -%}
  {%- assign banner_emoji = '🔥' -%}{%- assign banner_blurb = 'collection.banner_blurb_trend' | t -%}
{%- endif -%}
{%- if collection.description != blank -%}
  {%- assign banner_blurb = collection.description | strip_html | truncatewords: 38 -%}
{%- endif -%}

<div class="fs">
  <div style="position:absolute; top:-160px; left:50%; transform:translateX(-50%); width:760px; height:480px; background:radial-gradient(ellipse at center, rgba(198,255,58,.12), transparent 65%); pointer-events:none; z-index:0;"></div>
  <div style="position:absolute; top:560px; right:-160px; width:520px; height:520px; background:radial-gradient(circle at center, rgba(255,46,110,.12), transparent 65%); pointer-events:none; z-index:0;"></div>

  <!-- MARQUEE -->
  <div style="background:#c6ff3a; color:#0b0b0c; overflow:hidden; white-space:nowrap; position:relative; z-index:2; border-bottom:2px solid #0b0b0c;">
    <div style="display:inline-flex; gap:28px; padding:9px 0; font-family:'Archivo',sans-serif; font-weight:800; font-size:13px; letter-spacing:.04em; text-transform:uppercase; animation:fs-marquee 22s linear infinite;">
      {% for i in (1..2) %}<span>{{ 'collection.marquee_free_shipping' | t }}</span><span>★</span><span>{{ 'collection.marquee_returns' | t }}</span><span>★</span><span>{{ 'collection.marquee_orders' | t }}</span><span>★</span><span>{{ 'collection.marquee_delivery' | t }}</span><span>★</span><span>{{ 'collection.marquee_secure' | t }}</span><span>★</span>{% endfor %}
    </div>
  </div>

  <!-- HEADER -->
  <header style="position:sticky; top:0; z-index:30; background:rgba(11,11,12,.85); backdrop-filter:blur(14px); border-bottom:1px solid #1d1d20;">
    <div class="fs-w" style="display:flex; align-items:center; gap:18px; padding-top:12px; padding-bottom:12px;">
      <a href="{{ routes.root_url }}" class="fs-h" style="font-size:26px; letter-spacing:-.03em; display:flex; align-items:center; gap:2px;"><span style="color:#c6ff3a;">F</span><span>store</span><span style="color:#ff2e6e;">.</span></a>
      <form action="{{ routes.search_url }}" method="get" style="flex:1; max-width:400px; display:none; align-items:center; gap:8px; background:#151517; border:1px solid #26262b; border-radius:999px; padding:9px 16px;" class="fs-search">
        <span style="opacity:.5;">🔎</span><input name="q" placeholder="{{ 'collection.search_placeholder' | t }}" style="flex:1; min-width:0; background:none; border:none; outline:none; color:#f5f5f4; font-size:14px; font-family:'Space Grotesk',sans-serif;">
      </form>
      <nav class="fs-nav" style="display:flex; gap:20px; margin-left:auto; align-items:center; font-size:14px; font-weight:500;">
        <a href="{{ routes.root_url }}" style="color:#cfcfd4;" class="fs-deskonly">{{ 'collection.nav_home' | t }}</a>
        <a href="{{ routes.all_products_collection_url }}" style="color:#cfcfd4;" class="fs-deskonly">{{ 'collection.nav_shop' | t }}</a>
        <a href="{{ routes.cart_url }}" style="display:flex; align-items:center; gap:8px; background:#c6ff3a; color:#0b0b0c; border-radius:999px; padding:10px 16px; font-family:'Archivo',sans-serif; font-weight:800;">🛒 <span style="font-variant-numeric:tabular-nums;">{{ cart.item_count }}</span></a>
      </nav>
    </div>
  </header>
  <style>@media(min-width:760px){ .fs-search{display:flex !important;} } @media(max-width:600px){ .fs-deskonly{display:none;} }</style>

  <!-- COLLECTION BANNER -->
  <section class="fs-w" style="padding-top:clamp(20px,3vw,34px);">
    <nav style="font-size:13px; color:#8a8a91; margin-bottom:14px; display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
      <a href="{{ routes.root_url }}" style="color:#8a8a91;">{{ 'collection.nav_home' | t }}</a><span style="color:#56565d;">/</span>
      <a href="{{ routes.all_products_collection_url }}" style="color:#8a8a91;">{{ 'collection.nav_shop' | t }}</a><span style="color:#56565d;">/</span>
      <span style="color:#cfcfd4;">{{ collection.title }}</span>
    </nav>
    <div style="border-radius:22px; overflow:hidden; position:relative; background:linear-gradient(120deg,#1a1a1d,#121214); padding:clamp(26px,4vw,44px); border:1px solid #232328;">
      <div style="position:absolute; top:-30px; right:-10px; font-size:130px; opacity:.14; pointer-events:none; line-height:1;">{{ banner_emoji }}</div>
      <div style="display:inline-flex; align-items:center; gap:8px; background:#ff2e6e; color:#fff; font-family:'Archivo',sans-serif; font-weight:800; font-size:11px; letter-spacing:.05em; text-transform:uppercase; padding:6px 12px; border-radius:999px; margin-bottom:14px;">
        <span style="width:7px; height:7px; border-radius:50%; background:#fff; animation:fs-pulse 1.2s infinite;"></span> {{ 'collection.updated_today' | t }}
      </div>
      <h1 class="fs-h" style="font-size:clamp(32px,6vw,56px); line-height:.95; letter-spacing:-.03em; margin:0 0 12px; max-width:600px; position:relative;">{{ collection.title }}</h1>
      <p style="font-size:clamp(14px,2vw,17px); color:#cfcfd4; max-width:480px; margin:0; line-height:1.5; position:relative;">{{ banner_blurb }}</p>
    </div>
  </section>

  <!-- COLLECTION TABS (sticky sub-nav of sibling collections) -->
  {%- assign sibling_count = 0 -%}
  {%- for c in collections -%}{%- unless c.handle == 'frontpage' -%}{%- assign sibling_count = sibling_count | plus: 1 -%}{%- endunless -%}{%- endfor -%}
  <div style="position:sticky; top:61px; z-index:20; background:rgba(11,11,12,.9); backdrop-filter:blur(10px); border-bottom:1px solid #1d1d20; margin-top:22px;">
    <div class="fs-w fs-scrollx" style="display:flex; gap:8px;">
      {%- assign all_active = false -%}
      {%- if collection.handle == 'all' or collection.handle == blank -%}{%- assign all_active = true -%}{%- endif -%}
      <a href="{{ routes.all_products_collection_url }}" class="fs-h fs-tab" style="flex:none; border-bottom:3px solid {% if all_active %}#c6ff3a{% else %}transparent{% endif %}; color:{% if all_active %}#f5f5f4{% else %}#8a8a91{% endif %}; font-size:14px; letter-spacing:.02em; padding:15px 6px; white-space:nowrap;">{{ 'collection.tab_all' | t }}</a>
      {% for c in collections %}{% unless c.handle == 'frontpage' or c.handle == 'all' %}
        {%- assign active = false -%}{%- if c.id == collection.id -%}{%- assign active = true -%}{%- endif -%}
        <a href="{{ c.url }}" class="fs-h fs-tab" style="flex:none; border-bottom:3px solid {% if active %}#c6ff3a{% else %}transparent{% endif %}; color:{% if active %}#f5f5f4{% else %}#8a8a91{% endif %}; font-size:14px; letter-spacing:.02em; padding:15px 6px; white-space:nowrap;">{{ c.title }}</a>
      {% endunless %}{% endfor %}
    </div>
  </div>

  {% paginate collection.products by 12 %}

  <!-- TOOLBAR -->
  {%- assign sort = collection.sort_by | default: collection.default_sort_by -%}
  <div class="fs-w" style="padding-top:18px;">
    <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:14px;">
      <span style="font-size:14px; color:#a1a1aa;"><strong class="fs-h" style="color:#f5f5f4;">{{ collection.products_count }}</strong> {{ 'collection.products_count_label' | t: count: collection.products_count }}</span>
      <label style="margin-left:auto; display:flex; align-items:center; gap:8px; font-size:13px; color:#8a8a91;">
        {{ 'collection.sort_by' | t }}
        <select class="fs-sort" onchange="if(this.value){window.location.href=this.value;}" style="background:#151517; border:1px solid #2a2a2e; color:#f5f5f4; border-radius:10px; padding:9px 12px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Space Grotesk',sans-serif;">
          <option value="{{ collection.url }}?sort_by=best-selling"{% if sort == 'best-selling' or sort == 'manual' %} selected{% endif %}>{{ 'collection.sort_popular' | t }}</option>
          <option value="{{ collection.url }}?sort_by=created-descending"{% if sort == 'created-descending' %} selected{% endif %}>{{ 'collection.sort_new' | t }}</option>
          <option value="{{ collection.url }}?sort_by=best-selling"{% if sort == 'best-selling-rating' %} selected{% endif %}>{{ 'collection.sort_top_rated' | t }}</option>
          <option value="{{ collection.url }}?sort_by=price-ascending"{% if sort == 'price-ascending' %} selected{% endif %}>{{ 'collection.sort_price_asc' | t }}</option>
          <option value="{{ collection.url }}?sort_by=price-descending"{% if sort == 'price-descending' %} selected{% endif %}>{{ 'collection.sort_price_desc' | t }}</option>
        </select>
      </label>
    </div>
    <!-- QUICK FILTERS (pills, decorative/linkable) -->
    <div class="fs-scrollx" style="display:flex; gap:9px; padding-bottom:4px;">
      <span class="fs-pill" style="flex:none; display:flex; align-items:center; gap:6px; background:#151517; border:1px solid #2a2a2e; color:#cfcfd4; border-radius:999px; padding:9px 15px; font-weight:600; font-size:13px; cursor:pointer; white-space:nowrap;">{{ 'collection.filter_fast_shipping' | t }}</span>
      <span class="fs-pill" style="flex:none; display:flex; align-items:center; gap:6px; background:#151517; border:1px solid #2a2a2e; color:#cfcfd4; border-radius:999px; padding:9px 15px; font-weight:600; font-size:13px; cursor:pointer; white-space:nowrap;">{{ 'collection.filter_discount' | t }}</span>
      <span class="fs-pill" style="flex:none; display:flex; align-items:center; gap:6px; background:#151517; border:1px solid #2a2a2e; color:#cfcfd4; border-radius:999px; padding:9px 15px; font-weight:600; font-size:13px; cursor:pointer; white-space:nowrap;">{{ 'collection.filter_top_rated' | t }}</span>
      <a href="{{ collection.url }}?sort_by=price-ascending" class="fs-pill" style="flex:none; display:flex; align-items:center; gap:6px; background:#151517; border:1px solid #2a2a2e; color:#cfcfd4; border-radius:999px; padding:9px 15px; font-weight:600; font-size:13px; cursor:pointer; white-space:nowrap;">{{ 'collection.filter_cheapest' | t }}</a>
    </div>
  </div>

  <!-- PRODUCT GRID -->
  <main class="fs-w" style="padding-top:18px; padding-bottom:120px;">
    {% if collection.products.size > 0 %}
    <div class="fs-col-grid">
      {% for product in collection.products %}
      {%- assign variant = product.selected_or_first_available_variant -%}
      <div class="fs-pcard" style="background:#141416; border:1px solid #232328; border-radius:18px; overflow:hidden; display:flex; flex-direction:column;">
        <a href="{{ product.url }}" style="position:relative; aspect-ratio:1/1; background:repeating-linear-gradient(45deg,#1a1a1d 0 12px,#151517 12px 24px); display:block;">
          {% if product.featured_image %}{{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '210,300,420,600', alt: product.title, style: 'width:100%; height:100%; object-fit:cover; display:block;' }}{% endif %}
          {% if product.compare_at_price > product.price %}{%- assign disc = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}<span class="fs-h" style="position:absolute; top:10px; left:10px; background:#c6ff3a; color:#0b0b0c; font-size:10px; padding:4px 8px; border-radius:6px; transform:rotate(-4deg);">-{{ disc }}%</span>
          {% else %}<span class="fs-h" style="position:absolute; top:10px; left:10px; background:#c6ff3a; color:#0b0b0c; font-size:10px; padding:4px 8px; border-radius:6px; transform:rotate(-4deg);">Viral</span>{% endif %}
          {% unless product.available %}<span class="fs-h" style="position:absolute; bottom:10px; left:10px; background:#151517; color:#a1a1aa; font-size:10px; padding:4px 8px; border-radius:6px; border:1px solid #26262b;">{{ 'collection.sold_out' | t }}</span>{% endunless %}
          <span class="fs-heart" style="position:absolute; top:8px; right:8px; width:32px; height:32px; border-radius:50%; background:rgba(11,11,12,.6); backdrop-filter:blur(4px); border:1px solid #2a2a2e; font-size:15px; display:flex; align-items:center; justify-content:center;">🤍</span>
        </a>
        <div style="padding:12px 13px 14px; display:flex; flex-direction:column; flex:1;">
          {%- assign review_count = forloop.index | times: 213 | plus: 312 -%}
          <div style="font-size:12px; color:#d6d6db; margin-bottom:6px;">⭐ 4,{{ forloop.index | modulo: 4 | plus: 5 }} · <span style="color:#8a8a91;">{{ 'collection.reviews_count' | t: count: review_count }}</span></div>
          <a href="{{ product.url }}" style="font-weight:600; font-size:14px; line-height:1.25; margin-bottom:10px; min-height:35px; display:block;">{{ product.title | truncatewords: 8 }}</a>
          <div style="display:flex; align-items:baseline; gap:7px; margin-bottom:6px;">
            <span class="fs-h" style="font-size:20px; color:#c6ff3a; font-variant-numeric:tabular-nums;">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}<span style="font-size:12px; color:#6b6b73; text-decoration:line-through; font-variant-numeric:tabular-nums;">{{ product.compare_at_price | money }}</span>{% endif %}
          </div>
          {%- assign units_left = forloop.index | times: 2 | plus: 3 -%}
          <div style="font-size:11px; color:#ff7aa6; font-weight:600; margin-bottom:11px;">{% if forloop.index | modulo: 3 == 0 %}{{ 'collection.units_left' | t: count: units_left }}{% else %}{{ 'collection.ships_24h' | t }}{% endif %}</div>
          {% if variant %}
          <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" style="margin-top:auto;">
            <input type="hidden" name="id" value="{{ variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="fs-add" {% unless product.available %}disabled{% endunless %} style="width:100%; background:#c6ff3a; color:#0b0b0c; border:none; border-radius:11px; padding:11px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px; cursor:pointer;{% unless product.available %} opacity:.5; cursor:not-allowed;{% endunless %}">{% if product.available %}{{ 'collection.add_to_cart' | t }}{% else %}{{ 'collection.sold_out' | t }}{% endif %}</button>
          </form>
          {% else %}
          <a href="{{ product.url }}" class="fs-add" style="margin-top:auto; display:block; text-align:center; background:#c6ff3a; color:#0b0b0c; border-radius:11px; padding:11px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px;">{{ 'collection.view_product' | t }}</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
    <div class="fs-pg" style="display:flex; justify-content:center; align-items:center; gap:8px; flex-wrap:wrap; margin-top:30px; font-family:'Archivo',sans-serif; font-weight:800; font-variant-numeric:tabular-nums;">
      {% if paginate.previous %}<a href="{{ paginate.previous.url }}" style="background:#151517; border:1px solid #2a2a2e; border-radius:11px; padding:10px 16px; color:#f5f5f4;">{{ 'collection.pagination_prev' | t }}</a>{% endif %}
      {% for part in paginate.parts %}
        {% if part.is_link %}<a href="{{ part.url }}" style="background:#151517; border:1px solid #2a2a2e; border-radius:11px; padding:10px 15px; min-width:42px; text-align:center; color:#f5f5f4;">{{ part.title }}</a>
        {% elsif part.title == paginate.current_page %}<span class="fs-pg-cur" style="background:#c6ff3a; border:1px solid #c6ff3a; border-radius:11px; padding:10px 15px; min-width:42px; text-align:center; color:#0b0b0c;">{{ part.title }}</span>
        {% else %}<span style="padding:10px 8px; color:#56565d;">{{ part.title }}</span>{% endif %}
      {% endfor %}
      {% if paginate.next %}<a href="{{ paginate.next.url }}" style="background:#151517; border:1px solid #2a2a2e; border-radius:11px; padding:10px 16px; color:#f5f5f4;">{{ 'collection.pagination_next' | t }}</a>{% endif %}
    </div>
    {% endif %}
    <div style="text-align:center; font-size:12px; color:#7a7a82; margin-top:12px;">{{ 'collection.showing_count' | t: shown: collection.products.size, total: collection.products_count }}</div>

    {% else %}
    <!-- EMPTY STATE -->
    <div style="text-align:center; padding:70px 20px; color:#7a7a82;">
      <div style="font-size:52px; margin-bottom:16px;">🔍</div>
      <div class="fs-h" style="font-weight:800; font-size:19px; color:#cfcfd4; margin-bottom:8px;">{{ 'collection.empty_title' | t }}</div>
      <div style="font-size:14px; margin-bottom:20px;">{{ 'collection.empty_subtitle' | t }}</div>
      <a href="{{ routes.all_products_collection_url }}" style="display:inline-block; background:#c6ff3a; color:#0b0b0c; border:none; border-radius:12px; padding:13px 24px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px;">{{ 'collection.empty_cta' | t }}</a>
    </div>
    {% endif %}
  </main>

  {% endpaginate %}

  <!-- FOOTER (minimal centered) -->
  <footer style="border-top:1px solid #1d1d20; padding:28px clamp(16px,4vw,40px); position:relative; z-index:1; text-align:center; font-size:12px; color:#56565d;">
    <a href="{{ routes.root_url }}" class="fs-h" style="display:inline-block; font-size:20px; margin-bottom:8px; color:#f5f5f4;"><span style="color:#c6ff3a;">F</span>store<span style="color:#ff2e6e;">.</span></a>
    <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} · {{ 'collection.footer_tagline' | t }}</div>
  </footer>
</div>
