{% layout 'checkout' %}
{% comment %} Fstore Detalle Pedido — order tracking/detail, real Shopify order object. {% endcomment %}
{%- assign ffm = order.fulfillments.first -%}
{%- assign first_line = order.line_items.first -%}
{%- assign repeat_url = first_line.product.url -%}

{%- comment -%} Derive timeline state (1..4): 1 Confirmado, 2 Preparado, 3 En reparto, 4 Entregado {%- endcomment -%}
{%- assign ostep = 1 -%}
{%- if order.fulfillment_status == 'fulfilled' -%}{%- assign ostep = 3 -%}{%- endif -%}
{%- if ffm.shipment_status == 'in_transit' or ffm.shipment_status == 'out_for_delivery' -%}{%- assign ostep = 3 -%}{%- endif -%}
{%- if ffm.shipment_status == 'delivered' -%}{%- assign ostep = 4 -%}{%- endif -%}

<style>
  *{ box-sizing:border-box; }
  ::selection{ background:#c6ff3a; color:#0b0b0c; }
  @keyframes fs-pulse{ 0%,100%{ opacity:1; transform:scale(1); } 50%{ opacity:.35; transform:scale(.7); } }
  @keyframes fs-truck{ 0%,100%{ transform:translateX(0); } 50%{ transform:translateX(4px); } }
  .fs-ord{ background:#0b0b0c; color:#f5f5f4; font-family:'Space Grotesk',sans-serif; min-height:100vh; position:relative; overflow-x:hidden; }
  .fs-ord a{ color:inherit; text-decoration:none; }
  .fs-ord-h{ font-family:'Archivo',sans-serif; font-weight:900; text-transform:uppercase; letter-spacing:-.025em; }
  .fs-ord-num{ font-variant-numeric:tabular-nums; }
  .fs-ord-pulse{ animation:fs-pulse 1.4s infinite; }
  .fs-ord-truck{ display:inline-block; animation:fs-truck 1.1s ease-in-out infinite; }
  .fs-ord-account:hover{ color:#f5f5f4; }
  .fs-ord-back:hover{ color:#c6ff3a; }
  .fs-ord-item:hover{ border-color:#3a3a40; }
  .fs-ord-chip:hover{ border-color:#c6ff3a; background:#1b1b1e; color:#c6ff3a; }
  .fs-ord-act:hover{ border-color:#3a3a40; background:#16161a; }
  .fs-ord-btn{ display:inline-flex; align-items:center; justify-content:center; gap:9px; background:#c6ff3a; color:#0b0b0c; border:none; border-radius:13px; padding:15px 22px; font-family:'Archivo',sans-serif; font-weight:900; font-size:15px; text-transform:uppercase; letter-spacing:-.01em; cursor:pointer; box-shadow:0 5px 0 #7fae00; transition:background .12s ease; }
  .fs-ord-btn:hover{ background:#d4ff5e; }
  .fs-ord-btn:active{ transform:translateY(3px); box-shadow:0 2px 0 #7fae00; }
  .fs-ord-pink{ display:inline-flex; align-items:center; justify-content:center; gap:8px; background:#ff2e6e; color:#fff; border:none; border-radius:12px; padding:13px 20px; font-family:'Archivo',sans-serif; font-weight:900; font-size:14px; text-transform:uppercase; letter-spacing:-.01em; cursor:pointer; box-shadow:0 5px 0 #a01243; transition:background .12s ease; }
  .fs-ord-pink:hover{ background:#ff4d83; }
  .fs-ord-pink:active{ transform:translateY(3px); box-shadow:0 2px 0 #a01243; }
  @media (prefers-reduced-motion: reduce){ .fs-ord *{ animation:none !important; } }
</style>

<div class="fs-ord">
  <div style="position:absolute; top:-160px; left:50%; transform:translateX(-50%); width:700px; height:460px; background:radial-gradient(ellipse at center, rgba(198,255,58,.1), transparent 65%); pointer-events:none; z-index:0;"></div>

  <!-- HEADER -->
  <header style="position:sticky; top:0; z-index:20; background:rgba(11,11,12,.85); backdrop-filter:blur(14px); border-bottom:1px solid #1d1d20;">
    <div style="max-width:1060px; margin:0 auto; padding:13px clamp(16px,4vw,32px); display:flex; align-items:center; gap:14px;">
      <a href="{{ routes.root_url }}" class="fs-ord-h" style="font-size:24px; letter-spacing:-.03em; display:flex; align-items:center; gap:2px;"><span style="color:#c6ff3a;">F</span><span>store</span><span style="color:#ff2e6e;">.</span></a>
      <a href="{{ routes.account_url }}" class="fs-ord-account" style="margin-left:auto; display:flex; align-items:center; gap:8px; font-size:13px; color:#9a9aa1; transition:color .12s ease;"><span class="fs-ord-h" style="width:28px; height:28px; border-radius:50%; background:#c6ff3a; color:#0b0b0c; font-size:13px; display:flex; align-items:center; justify-content:center;">{{ customer.first_name | slice: 0 | upcase | default: 'F' }}</span> {{ 'order.my_account' | t }}</a>
    </div>
  </header>

  <!-- BREADCRUMB + TITLE -->
  <div style="max-width:1060px; margin:0 auto; padding:22px clamp(16px,4vw,32px) 0; position:relative; z-index:1;">
    <a href="{{ routes.account_url }}" class="fs-ord-back" style="display:inline-flex; align-items:center; gap:7px; font-size:13px; color:#8a8a91; margin-bottom:18px; transition:color .12s ease;">← {{ 'order.back_to_orders' | t }}</a>
    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; flex-wrap:wrap;">
      <div style="min-width:0;">
        <div class="fs-ord-h" style="font-size:12px; letter-spacing:.08em; color:#56565d; margin-bottom:6px;">{{ 'order.label' | t }}</div>
        <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
          <h1 class="fs-ord-h fs-ord-num" style="font-size:clamp(30px,5vw,44px); line-height:.95; margin:0;">{{ order.name }}</h1>
          {% if order.fulfillment_status_label %}
            <span class="fs-ord-h" style="display:inline-flex; align-items:center; gap:7px; padding:7px 13px; border-radius:999px; font-size:11px; letter-spacing:.03em; background:rgba(37,244,238,.13); color:#25f4ee;"><span class="fs-ord-truck">🚚</span> {{ order.fulfillment_status_label }}</span>
          {% else %}
            <span class="fs-ord-h" style="display:inline-flex; align-items:center; gap:7px; padding:7px 13px; border-radius:999px; font-size:11px; letter-spacing:.03em; background:rgba(198,255,58,.14); color:#c6ff3a;">⚡ {{ order.financial_status_label }}</span>
          {% endif %}
        </div>
      </div>
      <div style="text-align:right; min-width:0;">
        <div style="font-size:13px; color:#8a8a91;">{{ 'order.placed_on' | t: date: order.created_at | date: '%-d %b %Y' }}</div>
        <div class="fs-ord-num" style="font-size:14px; color:#d6d6db; margin-top:4px;">{{ 'order.item_count' | t: count: order.item_count }} · <strong style="color:#f5f5f4;">{{ order.total_price | money }}</strong></div>
      </div>
    </div>
  </div>

  <!-- MAIN GRID -->
  <main style="max-width:1060px; margin:0 auto; padding:22px clamp(16px,4vw,32px) 130px; position:relative; z-index:1; display:flex; flex-wrap:wrap; gap:clamp(20px,3.5vw,38px); align-items:flex-start;">
    <div style="flex:1 1 460px; min-width:0; display:flex; flex-direction:column; gap:20px;">

      <!-- LIVE TRACKING HERO -->
      <div style="position:relative; overflow:hidden; border:1px solid #232328; border-radius:20px; padding:clamp(20px,3vw,28px); background:linear-gradient(150deg, rgba(198,255,58,.08), #121214 55%);">
        <div style="display:flex; align-items:center; gap:9px; margin-bottom:14px;">
          <span class="fs-ord-pulse" style="width:9px; height:9px; border-radius:50%; background:#c6ff3a;"></span>
          <span class="fs-ord-h" style="font-size:12px; letter-spacing:.06em; color:#c6ff3a;">{{ 'order.live_tracking' | t }}</span>
        </div>

        {%- assign eta = ffm.estimated_delivery_at -%}
        <div class="fs-ord-h" style="font-size:clamp(24px,4vw,36px); line-height:1; margin:0 0 8px;">
          {%- if eta -%}
            {{ 'order.hero_arrives' | t: date: eta | date: '%-d %b' }}
          {%- elsif order.fulfillment_status == 'fulfilled' -%}
            {{ 'order.hero_on_the_way' | t }}
          {%- else -%}
            {{ 'order.hero_preparing' | t }}
          {%- endif -%}
        </div>
        <div style="font-size:14px; color:#a1a1aa; margin-bottom:22px;">
          {%- if ostep == 4 -%}{{ 'order.status_delivered' | t }}
          {%- elsif ostep == 3 -%}{{ 'order.status_out_for_delivery' | t }}
          {%- elsif order.fulfillment_status == 'fulfilled' -%}{{ 'order.status_shipped' | t }}
          {%- else -%}{{ 'order.status_preparing' | t }}{%- endif -%}
          {% if ffm.tracking_company != blank %}<span style="color:#d6d6db;"> · {{ 'order.carrier' | t }} <strong style="color:#f5f5f4;">{{ ffm.tracking_company }}</strong></span>{% endif %}
        </div>

        <!-- 4-STEP TIMELINE -->
        {% assign tstep_icons = '✓,📦,🚚,🏠' | split: ',' %}
        {% assign tstep_keys = 'order.step_confirmed,order.step_prepared,order.step_shipping,order.step_delivered' | split: ',' %}
        <div style="display:flex; align-items:flex-start; margin-bottom:24px;">
          {% for icon in tstep_icons %}
            {%- assign n = forloop.index -%}
            {%- if n <= ostep -%}{%- assign dotbg = '#c6ff3a' -%}{%- assign dotfg = '#0b0b0c' -%}{%- assign lab = '#e7e7e9' -%}
            {%- else -%}{%- assign dotbg = '#1d1d20' -%}{%- assign dotfg = '#56565d' -%}{%- assign lab = '#56565d' -%}{%- endif -%}
            <div style="flex:1; min-width:0; text-align:center; position:relative;">
              {% unless forloop.first %}<div style="position:absolute; top:15px; left:-50%; width:100%; height:2px; background:{% if n <= ostep %}#c6ff3a{% else %}#1d1d20{% endif %};"></div>{% endunless %}
              <div class="fs-ord-h" style="position:relative; z-index:1; width:32px; height:32px; margin:0 auto; border-radius:50%; background:{{ dotbg }}; color:{{ dotfg }}; display:flex; align-items:center; justify-content:center; font-size:15px;{% if n == ostep %} box-shadow:0 0 0 4px rgba(198,255,58,.15);{% endif %}">{{ icon }}</div>
              <div style="font-size:11px; color:{{ lab }}; margin-top:8px; letter-spacing:.01em;">{{ tstep_keys[forloop.index0] | t }}</div>
            </div>
          {% endfor %}
        </div>

        {%- if ffm.tracking_url != blank -%}{%- assign track_url = ffm.tracking_url -%}{%- else -%}{%- assign track_url = order.order_status_url -%}{%- endif -%}
        <a href="{{ track_url }}" class="fs-ord-btn" style="width:100%;">{{ 'order.track_on_map' | t }} 📍</a>
      </div>

      <!-- ITEMS -->
      <div style="background:#121214; border:1px solid #232328; border-radius:18px; padding:clamp(16px,3vw,22px);">
        <h2 class="fs-ord-h" style="font-size:clamp(18px,2.6vw,22px); margin:0 0 16px;">{{ 'order.items_title' | t }}</h2>
        <div style="display:flex; flex-direction:column; gap:12px;">
          {% for line in order.line_items %}
          <div class="fs-ord-item" style="display:flex; align-items:center; gap:14px; background:#151517; border:1px solid #232328; border-radius:14px; padding:12px; transition:border-color .12s ease;">
            <div style="position:relative; flex:none; width:66px; height:66px; border-radius:11px; overflow:hidden; background:repeating-linear-gradient(45deg,#1a1a1d 0 10px,#151517 10px 20px); display:flex; align-items:center; justify-content:center;">
              {% if line.image %}{{ line.image | image_url: width: 140 | image_tag: width: 66, height: 66, loading: 'lazy', alt: line.title, style: 'width:66px;height:66px;object-fit:cover;display:block;' }}{% else %}<span style="font-size:20px; opacity:.4;">🛍️</span>{% endif %}
              <span class="fs-ord-h fs-ord-num" style="position:absolute; top:-6px; right:-6px; min-width:20px; height:20px; padding:0 5px; border-radius:999px; background:#ff2e6e; color:#fff; font-size:11px; display:flex; align-items:center; justify-content:center;">{{ line.quantity }}</span>
            </div>
            <div style="flex:1; min-width:0;">
              <a href="{{ line.product.url }}" style="font-weight:600; font-size:15px; line-height:1.25; display:block;">{{ line.title }}</a>
              {% if line.variant.title and line.variant.title != 'Default Title' %}<div style="font-size:12px; color:#8a8a91; margin-top:3px;">{{ line.variant.title }}</div>{% endif %}
              <a href="{{ line.product.url }}" class="fs-ord-chip" style="display:inline-flex; align-items:center; gap:6px; margin-top:9px; background:#1b1b1e; border:1px solid #26262b; border-radius:999px; padding:6px 12px; font-size:12px; font-weight:600; color:#d6d6db; transition:border-color .12s ease, background .12s ease, color .12s ease;">🔁 {{ 'order.buy_again' | t }}</a>
            </div>
            <div class="fs-ord-num fs-ord-h" style="font-size:15px; white-space:nowrap; align-self:flex-start;">{{ line.final_line_price | money }}</div>
          </div>
          {% endfor %}
        </div>
      </div>

      <!-- DELIVERY + PAYMENT -->
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px;">
        <div style="background:#121214; border:1px solid #232328; border-radius:18px; padding:18px;">
          <div class="fs-ord-h" style="font-size:13px; letter-spacing:.03em; color:#d6d6db; margin-bottom:12px;">📍 {{ 'order.shipping_address' | t }}</div>
          {% if order.shipping_address %}
            <div style="font-size:14px; line-height:1.7; color:#b8b8bf;">{{ order.shipping_address | format_address }}</div>
          {% else %}
            <div style="font-size:14px; color:#8a8a91;">{{ 'order.no_shipping_address' | t }}</div>
          {% endif %}
        </div>
        <div style="background:#121214; border:1px solid #232328; border-radius:18px; padding:18px;">
          <div class="fs-ord-h" style="font-size:13px; letter-spacing:.03em; color:#d6d6db; margin-bottom:12px;">💳 {{ 'order.payment_method' | t }}</div>
          <div style="font-size:14px; color:#b8b8bf; line-height:1.7;">
            <div>{{ order.financial_status_label }}</div>
            <div class="fs-ord-num fs-ord-h" style="font-size:18px; color:#f5f5f4; margin-top:4px;">{{ order.total_price | money }}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT ASIDE -->
    <aside style="flex:1 1 300px; max-width:360px; position:sticky; top:84px; display:flex; flex-direction:column; gap:16px;">

      <!-- RESUMEN -->
      <div style="background:#121214; border:1px solid #232328; border-radius:20px; padding:20px;">
        <h2 class="fs-ord-h" style="font-size:15px; letter-spacing:.04em; margin:0 0 16px;">{{ 'order.summary' | t }}</h2>
        <div style="display:flex; flex-direction:column; gap:11px; font-size:14px;">
          <div style="display:flex; justify-content:space-between; gap:10px; color:#b8b8bf;">
            <span>{{ 'order.subtotal' | t }}</span><span class="fs-ord-num" style="color:#f5f5f4;">{{ order.line_items_subtotal_price | money }}</span>
          </div>
          {% for d in order.cart_level_discount_applications %}
          {%- assign discount_label = 'order.discount' | t -%}
          <div style="display:flex; justify-content:space-between; gap:10px; color:#c6ff3a;">
            <span>{{ d.title | default: discount_label }}</span><span class="fs-ord-num">−{{ d.total_allocated_amount | money }}</span>
          </div>
          {% endfor %}
          <div style="display:flex; justify-content:space-between; gap:10px; color:#b8b8bf;">
            <span>{{ 'order.shipping' | t }}</span>
            {% if order.shipping_price == 0 %}<span class="fs-ord-h" style="color:#c6ff3a; font-size:13px;">{{ 'order.free' | t }}</span>{% else %}<span class="fs-ord-num" style="color:#f5f5f4;">{{ order.shipping_price | money }}</span>{% endif %}
          </div>
          <div style="height:1px; background:#232328; margin:5px 0;"></div>
          <div style="display:flex; justify-content:space-between; align-items:baseline; gap:10px;">
            <span class="fs-ord-h" style="font-size:14px;">{{ 'order.total' | t }}</span>
            <span class="fs-ord-h fs-ord-num" style="font-size:26px; color:#c6ff3a; line-height:1;">{{ order.total_price | money }}</span>
          </div>
        </div>
      </div>

      <!-- ACTIONS -->
      <div style="background:#121214; border:1px solid #232328; border-radius:20px; padding:10px;">
        {% assign act_icons = '📄,↩️,⭐,🔁' | split: ',' %}
        {% assign act_kinds = 'invoice,return,rate,repeat' | split: ',' %}
        {% assign act_keys = 'order.action_invoice,order.action_return,order.action_rate,order.action_repeat' | split: ',' %}
        {% for icon in act_icons %}
          {%- assign akind = act_kinds[forloop.index0] -%}
          {%- if akind == 'repeat' -%}{%- assign aurl = repeat_url -%}
          {%- elsif akind == 'rate' -%}{%- assign aurl = repeat_url -%}
          {%- else -%}{%- assign aurl = order.order_status_url -%}{%- endif -%}
          <a href="{{ aurl }}" class="fs-ord-act" style="display:flex; align-items:center; gap:13px; padding:13px 12px; border-radius:14px; border:1px solid transparent; transition:border-color .12s ease, background .12s ease;">
            <span style="width:38px; height:38px; flex:none; border-radius:11px; background:#151517; border:1px solid #232328; display:flex; align-items:center; justify-content:center; font-size:17px;">{{ icon }}</span>
            <span style="flex:1; min-width:0; font-size:14px; font-weight:600; color:#e7e7e9;">{{ act_keys[forloop.index0] | t }}</span>
            <span style="color:#56565d; font-size:16px;">›</span>
          </a>
        {% endfor %}
      </div>

      <!-- HELP -->
      <div style="background:linear-gradient(150deg, rgba(255,46,110,.1), #121214 60%); border:1px solid #232328; border-radius:20px; padding:20px;">
        <div style="display:flex; align-items:center; gap:11px; margin-bottom:6px;">
          <span style="font-size:22px;">💬</span>
          <span class="fs-ord-h" style="font-size:16px;">{{ 'order.help_title' | t }}</span>
        </div>
        <p style="font-size:13px; color:#a1a1aa; margin:0 0 16px; line-height:1.5;">{{ 'order.help_body' | t }}</p>
        <a href="#" class="fs-ord-pink" style="width:100%;">{{ 'order.help_cta' | t }} 💬</a>
      </div>
    </aside>
  </main>
</div>
