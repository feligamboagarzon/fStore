{% layout 'checkout' %}
{% comment %}
  Fstore — ALTERNATE product template "landing".
  Long-form single-product viral conversion landing wired to the live `product` object.
  Selectable per-product in admin (Theme → product.landing). Mini header (no nav).
  Section order: hero · marquee · problem · solution · how · demo · reviews ·
  comparison · offer(#oferta) · guarantee · faq · final cta · sticky bar.
{% endcomment %}

{%- assign v = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
{%- assign saved_amount = product.compare_at_price | minus: product.price -%}
{%- assign price1 = product.price -%}
{%- assign price2 = product.price | times: 2 -%}
{%- assign price3 = product.price | times: 3 -%}

<style>
  *{ box-sizing:border-box; }
  ::selection{ background:#c6ff3a; color:#0b0b0c; }
  @keyframes fsl-marquee{ from{ transform:translateX(0); } to{ transform:translateX(-50%); } }
  @keyframes fsl-pulse{ 0%,100%{ opacity:1; transform:scale(1); } 50%{ opacity:.35; transform:scale(.7); } }
  @keyframes fsl-float{ 0%,100%{ transform:translateY(0) rotate(var(--r,0deg)); } 50%{ transform:translateY(-9px) rotate(var(--r,0deg)); } }
  .fsl{ background:#0b0b0c; color:#f5f5f4; font-family:'Space Grotesk',sans-serif; min-height:100vh; overflow-x:hidden; position:relative; padding-bottom:96px; }
  .fsl a{ color:inherit; text-decoration:none; }
  .fsl-h{ font-family:'Archivo',sans-serif; font-weight:900; text-transform:uppercase; letter-spacing:-.03em; }
  .fsl-num{ font-variant-numeric:tabular-nums; }
  .fsl-cta{ box-shadow:0 6px 0 #7fae00; transition:transform .08s, box-shadow .08s, background .12s; }
  .fsl-cta:active{ transform:translateY(3px); box-shadow:0 3px 0 #7fae00; }
  .fsl-cta:hover{ background:#d4ff5e; }
  .fsl-scroll{ display:flex; overflow-x:auto; scroll-snap-type:x mandatory; }
  .fsl-scroll::-webkit-scrollbar{ height:8px; } .fsl-scroll::-webkit-scrollbar-thumb{ background:#2a2a2e; border-radius:8px; }
  .fsl-pack{ cursor:pointer; transition:border-color .12s, background .12s; }
  .fsl-faq-q{ cursor:pointer; }
  .fsl-faq-i{ transition:transform .2s; }
  .fsl-faq.open .fsl-faq-i{ transform:rotate(45deg); }
  .fsl-faq .fsl-faq-a{ max-height:0; overflow:hidden; transition:max-height .28s ease; }
  .fsl-faq.open .fsl-faq-a{ max-height:360px; }
  @media (prefers-reduced-motion: reduce){ .fsl *{ animation-duration:.001ms !important; transition:none !important; } }
</style>

<div class="fsl">
  <div style="position:absolute; top:-160px; left:50%; transform:translateX(-50%); width:760px; height:500px; background:radial-gradient(ellipse at center, rgba(198,255,58,.16), transparent 65%); pointer-events:none; z-index:0;"></div>

  <!-- MINI HEADER -->
  <header style="position:relative; z-index:10; border-bottom:1px solid #1d1d20;">
    <div style="max-width:1000px; margin:0 auto; padding:13px clamp(16px,4vw,32px); display:flex; align-items:center; gap:12px;">
      <a href="{{ routes.root_url }}" class="fsl-h" style="font-size:23px; letter-spacing:-.03em; display:flex; align-items:center;"><span style="color:#c6ff3a;">F</span><span>store</span><span style="color:#ff2e6e;">.</span></a>
      <span style="margin-left:auto; font-size:12px; color:#9a9aa1; display:flex; align-items:center; gap:6px;">🔒 {{ 'landing.header_trust' | t }}</span>
    </div>
  </header>

  <!-- HERO -->
  <section style="position:relative; z-index:1; max-width:1000px; margin:0 auto; padding:clamp(26px,4vw,48px) clamp(16px,4vw,32px) 0; display:flex; flex-wrap:wrap; gap:clamp(26px,4vw,48px); align-items:center;">
    <div style="flex:1 1 360px; min-width:0;">
      <div style="display:inline-flex; align-items:center; gap:8px; background:#151517; border:1px solid #2a2a2e; border-radius:999px; padding:7px 13px; font-size:13px; margin-bottom:18px;"><span style="color:#d4ee5a;">★★★★★</span> <strong style="color:#fff;">{{ 'landing.rating_value' | t }}</strong> <span style="color:#8a8a91;">· {{ 'landing.rating_sold' | t }}</span></div>
      <h1 class="fsl-h" style="font-size:clamp(34px,6.5vw,62px); line-height:.94; letter-spacing:-.035em; margin:0 0 16px;">{{ product.title }}</h1>
      <p style="font-size:clamp(15px,2.2vw,18px); color:#c2c2c9; line-height:1.55; max-width:460px; margin:0 0 22px;">{% if product.description != blank %}{{ product.description | strip_html | truncatewords: 38 }}{% else %}{{ 'landing.hero_desc_fallback' | t }}{% endif %}</p>
      <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:20px;">
        <span class="fsl-h fsl-num" style="font-size:clamp(32px,5vw,44px); color:#c6ff3a; line-height:1;">{{ product.price | money }}</span>
        {% if on_sale %}<span style="font-size:18px; color:#6b6b73; text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
        {%- assign saved_money = saved_amount | money -%}<span class="fsl-h" style="background:#ff2e6e; color:#fff; font-weight:800; font-size:13px; padding:5px 10px; border-radius:6px; transform:rotate(-3deg);">{{ 'landing.hero_save' | t: amount: saved_money }}</span>{% endif %}
      </div>
      <a href="#oferta" class="fsl-cta fsl-h" style="display:inline-block; text-align:center; background:#c6ff3a; color:#0b0b0c; border-radius:14px; padding:18px 32px; font-size:18px;">{{ 'landing.hero_cta' | t }} →</a>
      <div style="display:flex; gap:16px; flex-wrap:wrap; margin-top:18px; font-size:12px; color:#8a8a91;"><span>⚡ {{ 'landing.trust_shipping' | t }}</span><span>↩️ {{ 'landing.trust_guarantee' | t }}</span><span>🔒 {{ 'landing.trust_secure' | t }}</span></div>
    </div>
    <div style="flex:1 1 320px; min-width:0; position:relative;">
      <div style="position:relative; aspect-ratio:4/5; border-radius:24px; overflow:hidden; border:1px solid #26262b; background:#121214; display:flex; align-items:center; justify-content:center;">
        {% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title | escape }}" width="720" height="900" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;">{% else %}<span style="font-family:monospace; font-size:12px; letter-spacing:.1em; color:#56565d; text-transform:uppercase;">[ foto producto · 4:5 ]</span>{% endif %}
      </div>
      <div class="fsl-h" style="position:absolute; top:-16px; left:-12px; background:#ff2e6e; color:#fff; font-size:14px; padding:10px 14px; border-radius:13px; transform:rotate(-9deg); box-shadow:0 8px 20px rgba(255,46,110,.4); --r:-9deg; animation:fsl-float 4s ease-in-out infinite;">🔥 {{ 'landing.hero_badge_tiktok' | t }}</div>
      <div style="position:absolute; bottom:20px; right:-12px; display:flex; align-items:center; gap:8px; background:#0b0b0c; border:1px solid #2a2a2e; border-radius:999px; padding:8px 13px; font-size:12px; box-shadow:0 8px 20px rgba(0,0,0,.5);"><span style="width:8px; height:8px; border-radius:50%; background:#25f4ee; animation:fsl-pulse 1.4s ease-in-out infinite;"></span>👀 <strong class="fsl-num" style="color:#fff;" id="fslViewers">1.284</strong> {{ 'landing.hero_viewers' | t }}</div>
    </div>
  </section>

  <!-- SOCIAL PROOF MARQUEE -->
  <div style="margin-top:clamp(30px,5vw,56px); background:#c6ff3a; color:#0b0b0c; overflow:hidden; white-space:nowrap; position:relative; z-index:2; border-top:2px solid #0b0b0c; border-bottom:2px solid #0b0b0c;">
    <div class="fsl-h" style="display:inline-flex; gap:24px; padding:10px 0; font-weight:800; font-size:13px; letter-spacing:.04em; animation:fsl-marquee 24s linear infinite;">
      {% for i in (1..2) %}<span>⭐ {{ 'landing.marquee_rating' | t }}</span><span>★</span><span>{{ 'landing.marquee_orders' | t }}</span><span>★</span><span>{{ 'landing.marquee_recommend' | t }}</span><span>★</span><span>{{ 'landing.marquee_views' | t }}</span><span>★</span><span>⚡ {{ 'landing.marquee_shipping' | t }}</span><span>★</span>{% endfor %}
    </div>
  </div>

  <!-- PROBLEM -->
  <section style="position:relative; z-index:1; max-width:760px; margin:0 auto; padding:clamp(40px,6vw,72px) clamp(16px,4vw,32px) 0;">
    <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,40px); line-height:1; margin:0 0 22px; text-align:center;">{{ 'landing.problem_title' | t }}</h2>
    <div style="display:flex; flex-direction:column; gap:11px;">
      {% assign pains = 'landing.problem_1,landing.problem_2,landing.problem_3,landing.problem_4' | split: ',' %}
      {% for pain in pains %}<div style="display:flex; align-items:flex-start; gap:12px; background:#121214; border:1px solid #232328; border-radius:14px; padding:15px 17px; font-size:clamp(14px,2vw,16px); color:#d6d6db;"><span style="flex:0 0 auto;">❌</span><span>{{ pain | t }}</span></div>{% endfor %}
    </div>
    <p style="text-align:center; font-size:clamp(16px,2.4vw,20px); color:#f5f5f4; font-weight:600; margin:26px 0 0;">{{ 'landing.problem_outro_html' | t }}</p>
  </section>

  <!-- SOLUTION FEATURES -->
  <section style="position:relative; z-index:1; max-width:1000px; margin:0 auto; padding:clamp(40px,6vw,72px) clamp(16px,4vw,32px) 0;">
    <div style="text-align:center; margin-bottom:30px;">
      <div class="fsl-h" style="color:#c6ff3a; font-weight:800; font-size:13px; letter-spacing:.08em; margin-bottom:10px;">{{ 'landing.solution_eyebrow' | t }}</div>
      <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,42px); line-height:1; margin:0;">{{ product.title }}</h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:14px;">
      {% assign feat_icons = '🌀|🔋|🤏|🤫' | split: '|' %}
      {% for i in (0..3) %}{% assign n = i | plus: 1 %}
      <div style="background:#121214; border:1px solid #232328; border-radius:18px; padding:22px 18px;">
        <div style="font-size:32px; margin-bottom:12px;">{{ feat_icons[i] }}</div>
        <div class="fsl-h" style="font-weight:800; font-size:17px; letter-spacing:-.01em; text-transform:none; margin-bottom:7px;">{% assign tkey = 'landing.feature_title_' | append: n %}{{ tkey | t }}</div>
        <div style="font-size:14px; color:#a1a1aa; line-height:1.5;">{% assign tkey = 'landing.feature_desc_' | append: n %}{{ tkey | t }}</div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="position:relative; z-index:1; max-width:1000px; margin:0 auto; padding:clamp(40px,6vw,72px) clamp(16px,4vw,32px) 0;">
    <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,42px); line-height:1; margin:0 0 30px; text-align:center;">{{ 'landing.how_title' | t }}</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px;">
      {% for i in (0..2) %}{% assign n = i | plus: 1 %}
      <div style="text-align:center;">
        <div class="fsl-h" style="width:56px; height:56px; border-radius:50%; background:#c6ff3a; color:#0b0b0c; display:flex; align-items:center; justify-content:center; font-size:24px; margin:0 auto 14px;">{{ n }}</div>
        <div class="fsl-h" style="font-weight:800; font-size:18px; text-transform:none; letter-spacing:-.01em; margin-bottom:7px;">{% assign tkey = 'landing.step_title_' | append: n %}{{ tkey | t }}</div>
        <div style="font-size:14px; color:#a1a1aa; line-height:1.5; max-width:240px; margin:0 auto;">{% assign tkey = 'landing.step_desc_' | append: n %}{{ tkey | t }}</div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- DEMO UGC -->
  <section style="background:#101012; border-top:1px solid #1d1d20; border-bottom:1px solid #1d1d20; position:relative; z-index:1; margin-top:clamp(40px,6vw,72px);">
    <div style="max-width:1000px; margin:0 auto; padding:clamp(34px,5vw,56px) 0;">
      <div style="text-align:center; padding:0 clamp(16px,4vw,32px); margin-bottom:22px;">
        <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,42px); line-height:1; margin:0 0 8px;">{{ 'landing.demo_title' | t }}</h2>
        <p style="font-size:14px; color:#8a8a91; margin:0;">{{ 'landing.demo_subtitle' | t }}</p>
      </div>
      <div class="fsl-scroll" style="gap:14px; padding:4px clamp(16px,4vw,32px) 10px;">
        {% assign clips = '@techdani|1,5M|@hogarconana|820k|@cleantok_es|2,1M|@minimal.home|390k|@gadgetguy|640k' | split: '|' %}
        {% for i in (0..4) %}{% assign b = i | times: 2 %}
        <div style="flex:0 0 auto; width:176px; scroll-snap-align:start; border-radius:16px; overflow:hidden; position:relative; aspect-ratio:9/16; background:repeating-linear-gradient(135deg,#1a1a1d 0 12px,#151517 12px 24px); cursor:pointer;">
          <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;"><div style="width:52px; height:52px; border-radius:50%; background:rgba(255,255,255,.16); backdrop-filter:blur(6px); border:1px solid rgba(255,255,255,.3); display:flex; align-items:center; justify-content:center; font-size:19px; color:#fff;">▶</div></div>
          <div style="position:absolute; left:0; right:0; bottom:0; padding:12px 11px; background:linear-gradient(transparent,rgba(0,0,0,.85));">
            <div style="font-weight:700; font-size:13px; margin-bottom:3px;">{{ clips[b] }}</div>
            <div style="font-size:11px; color:#c8c8cf;">❤️ {{ clips[b | plus: 1] }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section style="position:relative; z-index:1; max-width:1000px; margin:0 auto; padding:clamp(40px,6vw,72px) clamp(16px,4vw,32px) 0;">
    <div style="text-align:center; margin-bottom:28px;">
      <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,42px); line-height:1; margin:0 0 8px;">{{ 'landing.reviews_title' | t }}</h2>
      <p style="font-size:14px; color:#d4ee5a; margin:0;">★★★★★ {{ 'landing.reviews_subtitle' | t }}</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:14px;">
      {% assign rev_meta = 'M|María G.|#c6ff3a|J|Jorge R.|#25f4ee|L|Lucía P.|#ff2e6e' | split: '|' %}
      {% for i in (0..2) %}{% assign b = i | times: 3 %}{% assign n = i | plus: 1 %}
      <div style="background:#121214; border:1px solid #232328; border-radius:18px; padding:20px 18px;">
        <div style="display:flex; align-items:center; gap:11px; margin-bottom:12px;">
          <div class="fsl-h" style="width:42px; height:42px; border-radius:50%; background:{{ rev_meta[b | plus: 2] }}; color:#0b0b0c; display:flex; align-items:center; justify-content:center; font-size:17px;">{{ rev_meta[b] }}</div>
          <div><div style="font-weight:700; font-size:14px;">{{ rev_meta[b | plus: 1] }}</div><div style="font-size:11px; color:#25f4ee;">✓ {{ 'landing.review_verified' | t }}</div></div>
        </div>
        <div style="color:#d4ee5a; font-size:13px; margin-bottom:9px;">★★★★★</div>
        <p style="font-size:14px; color:#c2c2c9; line-height:1.55; margin:0;">{% assign tkey = 'landing.review_body_' | append: n %}{{ tkey | t }}</p>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- COMPARISON -->
  <section style="position:relative; z-index:1; max-width:760px; margin:0 auto; padding:clamp(40px,6vw,72px) clamp(16px,4vw,32px) 0;">
    <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,42px); line-height:1; margin:0 0 26px; text-align:center;">{{ 'landing.comparison_title' | t }}</h2>
    <div style="background:#121214; border:1px solid #232328; border-radius:18px; overflow:hidden;">
      <div style="display:grid; grid-template-columns:1.6fr 1fr 1fr; background:#151517; border-bottom:1px solid #232328;">
        <div style="padding:14px 16px;"></div>
        <div class="fsl-h" style="padding:14px 8px; text-align:center; color:#c6ff3a; font-weight:800; font-size:14px;">Fstore</div>
        <div style="padding:14px 8px; text-align:center; color:#8a8a91; font-size:13px; font-weight:600;">{{ 'landing.comparison_others' | t }}</div>
      </div>
      {% assign row_marks = '❌|🐌|❌|❌|❌' | split: '|' %}
      {% for i in (0..4) %}{% assign n = i | plus: 1 %}
      <div style="display:grid; grid-template-columns:1.6fr 1fr 1fr; {% unless forloop.last %}border-bottom:1px solid #1d1d20;{% endunless %} align-items:center;">
        <div style="padding:13px 16px; font-size:14px; color:#e4e4e7;">{% assign tkey = 'landing.comparison_row_' | append: n %}{{ tkey | t }}</div>
        <div style="padding:13px 8px; text-align:center; font-size:17px;">✅</div>
        <div style="padding:13px 8px; text-align:center; font-size:16px;">{{ row_marks[i] }}</div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- OFFER -->
  <section id="oferta" style="position:relative; z-index:1; max-width:760px; margin:0 auto; padding:clamp(40px,6vw,72px) clamp(16px,4vw,32px) 0;">
    <div style="border:1px solid #2e3a14; border-radius:24px; background:linear-gradient(160deg,#15170d,#121214 55%); padding:clamp(22px,4vw,38px);">
      <div style="text-align:center; margin-bottom:22px;">
        <div style="display:inline-flex; align-items:center; gap:8px; background:#ff2e6e; color:#fff; font-weight:700; font-size:13px; padding:7px 14px; border-radius:999px; margin-bottom:16px;">⏳ {{ 'landing.offer_countdown_label' | t }} <strong class="fsl-num" id="fslCount">02:59:59</strong></div>
        <h2 class="fsl-h" style="font-size:clamp(24px,4vw,38px); line-height:1; margin:0 0 8px;">{{ 'landing.offer_title' | t }}</h2>
        <p style="font-size:14px; color:#a1a1aa; margin:0;">{{ 'landing.offer_subtitle' | t }}</p>
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" id="fslForm" style="display:flex; flex-direction:column; gap:11px;">
        <input type="hidden" name="id" value="{{ v.id }}">
        <input type="hidden" name="quantity" id="fslQty" value="1">
        {%- comment -%} Buy-now: after adding, go straight to Shopify's secure checkout (shows configured processors, e.g. MercadoPago). {%- endcomment -%}
        <input type="hidden" name="return_to" value="/checkout">

        <label class="fsl-pack" data-qty="1" data-price="{{ price1 }}" data-on="1" style="display:flex; align-items:center; gap:14px; background:#15170d; border:2px solid #c6ff3a; border-radius:16px; padding:15px 17px;">
          <span class="fsl-radio" style="flex:0 0 auto; width:20px; height:20px; border-radius:50%; border:2px solid #c6ff3a; background:#c6ff3a;"></span>
          <span style="flex:1;"><span class="fsl-h" style="font-weight:800; font-size:16px; text-transform:none; letter-spacing:-.01em;">{{ 'landing.pack1_name' | t }}</span><br><span style="font-size:12px; color:#8a8a91;">{{ 'landing.pack1_note' | t }}</span></span>
          <span class="fsl-h fsl-num" style="font-size:19px; color:#c6ff3a;">{{ price1 | money }}</span>
        </label>

        <label class="fsl-pack" data-qty="2" data-price="{{ price2 }}" data-on="0" style="display:flex; align-items:center; gap:14px; background:#141416; border:2px solid #232328; border-radius:16px; padding:15px 17px; position:relative;">
          <span class="fsl-h" style="position:absolute; top:-11px; right:14px; background:#ff2e6e; color:#fff; font-weight:800; font-size:10px; padding:4px 9px; border-radius:6px;">{{ 'landing.pack_badge_popular' | t }}</span>
          <span class="fsl-radio" style="flex:0 0 auto; width:20px; height:20px; border-radius:50%; border:2px solid #56565d; background:transparent;"></span>
          <span style="flex:1;"><span class="fsl-h" style="font-weight:800; font-size:16px; text-transform:none; letter-spacing:-.01em;">{{ 'landing.pack2_name' | t }}</span><br><span style="font-size:12px; color:#8a8a91;">{{ 'landing.pack2_note' | t }}</span></span>
          <span class="fsl-h fsl-num" style="font-size:19px; color:#c6ff3a;">{{ price2 | money }}</span>
        </label>

        <label class="fsl-pack" data-qty="3" data-price="{{ price3 }}" data-on="0" style="display:flex; align-items:center; gap:14px; background:#141416; border:2px solid #232328; border-radius:16px; padding:15px 17px; position:relative;">
          <span class="fsl-h" style="position:absolute; top:-11px; right:14px; background:#c6ff3a; color:#0b0b0c; font-weight:800; font-size:10px; padding:4px 9px; border-radius:6px;">{{ 'landing.pack_badge_best' | t }}</span>
          <span class="fsl-radio" style="flex:0 0 auto; width:20px; height:20px; border-radius:50%; border:2px solid #56565d; background:transparent;"></span>
          <span style="flex:1;"><span class="fsl-h" style="font-weight:800; font-size:16px; text-transform:none; letter-spacing:-.01em;">{{ 'landing.pack3_name' | t }}</span><br><span style="font-size:12px; color:#8a8a91;">{{ 'landing.pack3_note' | t }}</span></span>
          <span class="fsl-h fsl-num" style="font-size:19px; color:#c6ff3a;">{{ price3 | money }}</span>
        </label>

        {% if product.available %}
        <button type="submit" class="fsl-cta fsl-h" style="margin-top:7px; background:#c6ff3a; color:#0b0b0c; border:none; border-radius:14px; padding:18px; font-size:18px; cursor:pointer; width:100%;">{{ 'landing.buy_now' | t }} · <span id="fslBtnPrice" class="fsl-num">{{ price1 | money }}</span></button>
        {% else %}
        <button type="button" disabled class="fsl-h" style="margin-top:7px; background:#232328; color:#8a8a91; border:none; border-radius:14px; padding:18px; font-size:18px; width:100%; cursor:not-allowed;">{{ 'landing.sold_out' | t }}</button>
        {% endif %}
      </form>
      <div style="display:flex; justify-content:center; gap:18px; flex-wrap:wrap; margin-top:16px; font-size:12px; color:#8a8a91;"><span>🔒 {{ 'landing.trust_secure' | t }}</span><span>⚡ {{ 'landing.trust_shipping' | t }}</span><span>↩️ {{ 'landing.trust_returns_short' | t }}</span></div>
    </div>
  </section>

  <!-- GUARANTEE -->
  <section style="position:relative; z-index:1; max-width:760px; margin:0 auto; padding:clamp(40px,6vw,64px) clamp(16px,4vw,32px) 0; text-align:center;">
    <div style="width:70px; height:70px; border-radius:50%; background:#15170d; border:1px solid #2e3a14; display:flex; align-items:center; justify-content:center; font-size:32px; margin:0 auto 16px;">🛡️</div>
    <h2 class="fsl-h" style="font-size:clamp(22px,3.5vw,32px); line-height:1.05; margin:0 0 12px;">{{ 'landing.guarantee_title' | t }}</h2>
    <p style="font-size:clamp(14px,2vw,16px); color:#a1a1aa; line-height:1.6; max-width:520px; margin:0 auto;">{{ 'landing.guarantee_body' | t }}</p>
  </section>

  <!-- FAQ -->
  <section style="position:relative; z-index:1; max-width:760px; margin:0 auto; padding:clamp(40px,6vw,64px) clamp(16px,4vw,32px) 0;">
    <h2 class="fsl-h" style="font-size:clamp(26px,4.5vw,40px); line-height:1; margin:0 0 24px; text-align:center;">{{ 'landing.faq_title' | t }}</h2>
    <div style="display:flex; flex-direction:column; gap:11px;">
      {% for i in (0..3) %}{% assign n = i | plus: 1 %}
      <div class="fsl-faq" style="background:#121214; border:1px solid #232328; border-radius:14px; overflow:hidden;">
        <div class="fsl-faq-q" style="display:flex; align-items:center; gap:12px; padding:16px 18px;">
          <span style="flex:1; font-weight:700; font-size:clamp(14px,2vw,16px);">{% assign tkey = 'landing.faq_q_' | append: n %}{{ tkey | t }}</span>
          <span class="fsl-faq-i fsl-h" style="flex:0 0 auto; color:#c6ff3a; font-size:22px; line-height:1;">+</span>
        </div>
        <div class="fsl-faq-a"><p style="padding:0 18px 16px; margin:0; font-size:14px; color:#a1a1aa; line-height:1.6;">{% assign tkey = 'landing.faq_a_' | append: n %}{{ tkey | t }}</p></div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- FINAL CTA -->
  <section style="position:relative; z-index:1; max-width:760px; margin:0 auto; padding:clamp(44px,6vw,80px) clamp(16px,4vw,32px) clamp(40px,6vw,64px); text-align:center;">
    <h2 class="fsl-h" style="font-size:clamp(28px,5vw,48px); line-height:.96; margin:0 0 14px;">{{ 'landing.final_title_html' | t }}</h2>
    <p style="font-size:clamp(15px,2.2vw,18px); color:#c2c2c9; line-height:1.55; max-width:480px; margin:0 auto 24px;">{{ 'landing.final_subtitle' | t }}</p>
    <a href="#oferta" class="fsl-cta fsl-h" style="display:inline-block; background:#c6ff3a; color:#0b0b0c; border-radius:14px; padding:18px 36px; font-size:18px;">{{ 'landing.final_cta' | t }} · {{ product.price | money }}</a>
    <div style="font-size:13px; color:#8a8a91; margin-top:16px;">💳 {{ 'landing.payment_methods' | t }}</div>
  </section>

  <!-- STICKY BAR -->
  <div style="position:fixed; left:0; right:0; bottom:0; z-index:40; background:rgba(11,11,12,.92); backdrop-filter:blur(14px); border-top:1px solid #232328;">
    <div style="max-width:1000px; margin:0 auto; padding:11px clamp(14px,4vw,32px); display:flex; align-items:center; gap:14px;">
      <div style="display:flex; align-items:baseline; gap:9px; min-width:0;">
        {% if on_sale %}<span style="font-size:14px; color:#6b6b73; text-decoration:line-through;">{{ product.compare_at_price | money }}</span>{% endif %}
        <span class="fsl-h fsl-num" style="font-size:22px; color:#c6ff3a;">{{ product.price | money }}</span>
      </div>
      {% if product.available %}
      <a href="#oferta" class="fsl-cta fsl-h" style="margin-left:auto; background:#c6ff3a; color:#0b0b0c; border-radius:12px; padding:13px 22px; font-size:15px; white-space:nowrap;">{{ 'landing.sticky_buy' | t }}</a>
      {% else %}
      <span class="fsl-h" style="margin-left:auto; background:#232328; color:#8a8a91; border-radius:12px; padding:13px 22px; font-size:15px;">{{ 'landing.sold_out' | t }}</span>
      {% endif %}
    </div>
  </div>
</div>

<script>
(function(){
  var end = Date.now() + ((2*3600)+(59*60)+59)*1000;
  function pad(n){ return (n<10?'0':'')+n; }
  var el = document.getElementById('fslCount');
  if(el) setInterval(function(){
    var d = end - Date.now(); if(d<=0){ end = Date.now()+3*3600*1000; d = end-Date.now(); }
    el.textContent = pad(Math.floor(d/3.6e6))+':'+pad(Math.floor(d%3.6e6/6e4))+':'+pad(Math.floor(d%6e4/1e3));
  },1000);
  var vw = document.getElementById('fslViewers');
  if(vw) setInterval(function(){ vw.textContent=(940+Math.floor(Math.random()*1040)).toLocaleString('es-ES'); },1900);
  var packs = document.querySelectorAll('.fsl-pack');
  var qtyEl = document.getElementById('fslQty');
  var btnPrice = document.getElementById('fslBtnPrice');
  function money(cents){ try{ return (cents/100).toLocaleString('es-ES',{style:'currency',currency:'{{ shop.currency }}'}); }catch(e){ return (cents/100).toFixed(2); } }
  packs.forEach(function(p){
    p.addEventListener('click', function(){
      packs.forEach(function(x){
        x.setAttribute('data-on','0'); x.style.borderColor='#232328'; x.style.background='#141416';
        var r=x.querySelector('.fsl-radio'); if(r){ r.style.borderColor='#56565d'; r.style.background='transparent'; }
      });
      p.setAttribute('data-on','1'); p.style.borderColor='#c6ff3a'; p.style.background='#15170d';
      var r=p.querySelector('.fsl-radio'); if(r){ r.style.borderColor='#c6ff3a'; r.style.background='#c6ff3a'; }
      if(qtyEl) qtyEl.value = p.getAttribute('data-qty');
      if(btnPrice) btnPrice.textContent = money(parseInt(p.getAttribute('data-price'),10));
    });
  });
  document.querySelectorAll('.fsl-faq-q').forEach(function(q){
    q.addEventListener('click', function(){ q.closest('.fsl-faq').classList.toggle('open'); });
  });
})();
</script>
