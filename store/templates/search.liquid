{% layout 'checkout' %}
{% comment %} Fstore Búsqueda — Claude Design recreated, wired to real Shopify `search`. {% endcomment %}
<style>
  *{ box-sizing:border-box; }
  ::selection{ background:#c6ff3a; color:#0b0b0c; }
  @keyframes fs-pulse{ 0%,100%{ opacity:1; transform:scale(1); } 50%{ opacity:.35; transform:scale(.7); } }
  .fss{ background:#0b0b0c; color:#f5f5f4; font-family:'Space Grotesk',sans-serif; min-height:100vh; overflow-x:hidden; position:relative; }
  .fss a{ color:inherit; text-decoration:none; }
  .fss-w{ max-width:1100px; margin:0 auto; padding-left:clamp(16px,4vw,32px); padding-right:clamp(16px,4vw,32px); position:relative; z-index:1; }
  .fss-h{ font-family:'Archivo',sans-serif; font-weight:900; text-transform:uppercase; letter-spacing:-.025em; }
  .fss-pill:hover{ border-color:#c6ff3a; background:#1b1b1e; }
  .fss-hot:hover{ background:rgba(255,46,110,.18); border-color:#ff2e6e; }
  .fss-pcard{ transition:border-color .18s, transform .18s; }
  .fss-pcard:hover{ border-color:#3a3a40; transform:translateY(-3px); }
  .fss-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(min(100%,200px),1fr)); gap:clamp(12px,2vw,18px); }
  .fss-add:hover{ background:#d4ff5e; }
  .fss-form:focus-within{ border-color:#c6ff3a; }
  .fss-pg a:hover, .fss-pg .fss-pg-cur{ background:#1b1b1e; border-color:#c6ff3a; }
  @media (prefers-reduced-motion: reduce){ .fss *{ animation-duration:.001ms !important; transition:none !important; } }
</style>

<div class="fss">
  <div style="position:absolute; top:-160px; left:50%; transform:translateX(-50%); width:700px; height:420px; background:radial-gradient(ellipse at center, rgba(198,255,58,.1), transparent 65%); pointer-events:none; z-index:0;"></div>

  <!-- HEADER WITH SEARCH -->
  <header style="position:sticky; top:0; z-index:30; background:rgba(11,11,12,.9); backdrop-filter:blur(14px); border-bottom:1px solid #1d1d20;">
    <div class="fss-w" style="display:flex; align-items:center; gap:14px; padding-top:12px; padding-bottom:12px;">
      <a href="{{ routes.root_url }}" class="fss-h" style="font-size:23px; letter-spacing:-.03em; display:flex; align-items:center; gap:1px; flex:none;"><span style="color:#c6ff3a;">F</span><span>store</span><span style="color:#ff2e6e;">.</span></a>
      <form action="{{ routes.search_url }}" method="get" role="search" class="fss-form" style="flex:1; display:flex; align-items:center; gap:10px; background:#151517; border:2px solid #26262b; border-radius:999px; padding:9px 18px; min-width:0;">
        <span style="opacity:.6; font-size:16px;">🔎</span>
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search_page.search_placeholder' | t }}" autofocus style="flex:1; min-width:0; background:none; border:none; outline:none; color:#f5f5f4; font-size:15px; font-family:'Space Grotesk',sans-serif;">
        <input type="hidden" name="type" value="product">
      </form>
      <a href="{{ routes.cart_url }}" style="flex:none; display:flex; align-items:center; gap:7px; background:#c6ff3a; color:#0b0b0c; border-radius:999px; padding:10px 15px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px;">🛒 <span style="font-variant-numeric:tabular-nums;">{{ cart.item_count }}</span></a>
    </div>
  </header>

  <main class="fss-w" style="padding-top:clamp(20px,3vw,32px); padding-bottom:120px;">

    {%- comment -%} Trending terms used in idle + no-results states (first 2 are hot/pink). `trending` = search query (data, stays ES); `trending_labels` = visible labels via | t. {%- endcomment -%}
    {%- assign trending = 'Aspiradora,Lámpara Sunset,Proyector galaxia,Auriculares,Belleza,Gadgets' | split: ',' -%}
    {%- assign trending_labels = 'search_page.trend_1,search_page.trend_2,search_page.trend_3,search_page.trend_4,search_page.trend_5,search_page.trend_6' | split: ',' -%}

    {%- unless search.performed -%}
    <!-- ============ IDLE STATE ============ -->

    <!-- RECENT (localStorage, non-blocking) -->
    <div id="fssRecentWrap" style="display:none; margin-bottom:30px;">
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px; flex-wrap:wrap;">
        <h2 class="fss-h" style="font-size:15px; color:#9a9aa1; margin:0;">{{ 'search_page.recent_heading' | t }}</h2>
        <button id="fssRecentClear" type="button" style="margin-left:auto; background:none; border:none; color:#6b6b73; font-size:13px; font-family:'Space Grotesk',sans-serif; cursor:pointer; font-weight:600;">{{ 'search_page.recent_clear' | t }}</button>
      </div>
      <div id="fssRecentPills" style="display:flex; flex-wrap:wrap; gap:10px;"></div>
    </div>

    <!-- TRENDING -->
    <section style="margin-bottom:34px;">
      <h2 class="fss-h" style="font-size:clamp(20px,3vw,26px); margin:0 0 16px;">🔥 {{ 'search_page.trending_heading' | t }}</h2>
      <div style="display:flex; flex-wrap:wrap; gap:10px;">
        {% for term in trending %}
          {%- assign term_label = trending_labels[forloop.index0] -%}
          {% if forloop.index <= 2 %}
          <a href="{{ routes.search_url }}?q={{ term | url_encode }}&type=product" class="fss-hot" style="display:flex; align-items:center; gap:7px; background:rgba(255,46,110,.1); border:1px solid rgba(255,46,110,.35); color:#ff9cba; border-radius:999px; padding:9px 15px; font-weight:600; font-size:14px;">🔥 {{ term_label | t }}</a>
          {% else %}
          <a href="{{ routes.search_url }}?q={{ term | url_encode }}&type=product" class="fss-pill" style="display:flex; align-items:center; gap:7px; background:#151517; border:1px solid #2a2a2e; color:#d4d4db; border-radius:999px; padding:9px 15px; font-weight:600; font-size:14px;">{{ term_label | t }}</a>
          {% endif %}
        {% endfor %}
      </div>
    </section>

    <!-- POPULAR -->
    {%- assign popular = collections['all'].products -%}
    {% if popular.size > 0 %}
    <section>
      <h2 class="fss-h" style="font-size:clamp(20px,3vw,26px); margin:0 0 16px;">{{ 'search_page.bestsellers_heading' | t }}</h2>
      <div class="fss-grid">
        {% for item in popular limit: 8 %}
          {%- assign variant = item.selected_or_first_available_variant -%}
          <div class="fss-pcard" style="background:#141416; border:1px solid #232328; border-radius:18px; overflow:hidden; display:flex; flex-direction:column;">
            <a href="{{ item.url }}" style="position:relative; aspect-ratio:1/1; background:repeating-linear-gradient(45deg,#1a1a1d 0 12px,#151517 12px 24px); display:block;">
              {% if item.featured_image %}{{ item.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', widths: '200,300,420,500', alt: item.title, style: 'width:100%; height:100%; object-fit:cover; display:block;' }}{% endif %}
              {% if item.compare_at_price > item.price %}{%- assign disc = item.compare_at_price | minus: item.price | times: 100.0 | divided_by: item.compare_at_price | round -%}<span class="fss-h" style="position:absolute; top:10px; left:10px; background:#c6ff3a; color:#0b0b0c; font-size:10px; padding:4px 8px; border-radius:6px; transform:rotate(-4deg);">-{{ disc }}%</span>{% else %}<span class="fss-h" style="position:absolute; top:10px; left:10px; background:#c6ff3a; color:#0b0b0c; font-size:10px; padding:4px 8px; border-radius:6px; transform:rotate(-4deg);">{{ 'search_page.badge_viral' | t }}</span>{% endif %}
            </a>
            <div style="padding:12px 13px 14px; display:flex; flex-direction:column; flex:1;">
              {%- assign reviews_count = forloop.index | times: 213 | plus: 312 -%}
              <div style="font-size:12px; color:#d6d6db; margin-bottom:6px;">⭐ 4,{{ forloop.index | modulo: 4 | plus: 5 }} · <span style="color:#8a8a91;">{{ 'search_page.reviews_html' | t: count: reviews_count }}</span></div>
              <a href="{{ item.url }}" style="font-weight:600; font-size:14px; line-height:1.25; margin-bottom:10px; min-height:35px; display:block;">{{ item.title | truncatewords: 8 }}</a>
              <div style="display:flex; align-items:baseline; gap:7px; margin-bottom:11px;">
                <span class="fss-h" style="font-size:20px; color:#c6ff3a; font-variant-numeric:tabular-nums;">{{ item.price | money }}</span>
                {% if item.compare_at_price > item.price %}<span style="font-size:12px; color:#6b6b73; text-decoration:line-through; font-variant-numeric:tabular-nums;">{{ item.compare_at_price | money }}</span>{% endif %}
              </div>
              {% if variant %}
              <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" style="margin-top:auto;">
                <input type="hidden" name="id" value="{{ variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="fss-add" {% unless item.available %}disabled{% endunless %} style="width:100%; background:#c6ff3a; color:#0b0b0c; border:none; border-radius:11px; padding:11px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px; cursor:pointer;{% unless item.available %} opacity:.5; cursor:not-allowed;{% endunless %}">{% if item.available %}{{ 'search_page.add_to_cart' | t }} 🛒{% else %}{{ 'search_page.sold_out' | t }}{% endif %}</button>
              </form>
              {% else %}
              <a href="{{ item.url }}" class="fss-add" style="margin-top:auto; display:block; text-align:center; background:#c6ff3a; color:#0b0b0c; border-radius:11px; padding:11px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px;">{{ 'search_page.view_product' | t }} →</a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {%- else -%}
      {%- if search.results_count > 0 -%}
      <!-- ============ RESULTS STATE ============ -->
      <div style="margin-bottom:18px;">
        <h1 class="fss-h" style="font-size:clamp(20px,3vw,26px); margin:0 0 6px; line-height:1.1;">{{ 'search_page.results_for_html' | t: terms: search.terms }}</h1>
        <p style="font-size:14px; color:#8a8a91; margin:0;">{{ 'search_page.results_count' | t: count: search.results_count }}</p>
      </div>

      {% paginate search.results by 20 %}
      <div class="fss-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {%- assign variant = item.selected_or_first_available_variant -%}
            <div class="fss-pcard" style="background:#141416; border:1px solid #232328; border-radius:18px; overflow:hidden; display:flex; flex-direction:column;">
              <a href="{{ item.url }}" style="position:relative; aspect-ratio:1/1; background:repeating-linear-gradient(45deg,#1a1a1d 0 12px,#151517 12px 24px); display:block;">
                {% if item.featured_image %}{{ item.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', widths: '200,300,420,500', alt: item.title, style: 'width:100%; height:100%; object-fit:cover; display:block;' }}{% endif %}
                {% if item.compare_at_price > item.price %}{%- assign disc = item.compare_at_price | minus: item.price | times: 100.0 | divided_by: item.compare_at_price | round -%}<span class="fss-h" style="position:absolute; top:10px; left:10px; background:#c6ff3a; color:#0b0b0c; font-size:10px; padding:4px 8px; border-radius:6px; transform:rotate(-4deg);">-{{ disc }}%</span>{% else %}<span class="fss-h" style="position:absolute; top:10px; left:10px; background:#c6ff3a; color:#0b0b0c; font-size:10px; padding:4px 8px; border-radius:6px; transform:rotate(-4deg);">{{ 'search_page.badge_viral' | t }}</span>{% endif %}
                {% unless item.available %}<span class="fss-h" style="position:absolute; bottom:10px; left:10px; background:#151517; color:#a1a1aa; font-size:10px; padding:4px 8px; border-radius:6px; border:1px solid #26262b;">{{ 'search_page.sold_out' | t }}</span>{% endunless %}
              </a>
              <div style="padding:12px 13px 14px; display:flex; flex-direction:column; flex:1;">
                {%- assign reviews_count = forloop.index | times: 213 | plus: 312 -%}
              <div style="font-size:12px; color:#d6d6db; margin-bottom:6px;">⭐ 4,{{ forloop.index | modulo: 4 | plus: 5 }} · <span style="color:#8a8a91;">{{ 'search_page.reviews_html' | t: count: reviews_count }}</span></div>
                <a href="{{ item.url }}" style="font-weight:600; font-size:14px; line-height:1.25; margin-bottom:10px; min-height:35px; display:block;">{{ item.title | truncatewords: 8 }}</a>
                <div style="display:flex; align-items:baseline; gap:7px; margin-bottom:11px;">
                  <span class="fss-h" style="font-size:20px; color:#c6ff3a; font-variant-numeric:tabular-nums;">{{ item.price | money }}</span>
                  {% if item.compare_at_price > item.price %}<span style="font-size:12px; color:#6b6b73; text-decoration:line-through; font-variant-numeric:tabular-nums;">{{ item.compare_at_price | money }}</span>{% endif %}
                </div>
                {% if variant %}
                <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" style="margin-top:auto;">
                  <input type="hidden" name="id" value="{{ variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="fss-add" {% unless item.available %}disabled{% endunless %} style="width:100%; background:#c6ff3a; color:#0b0b0c; border:none; border-radius:11px; padding:11px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px; cursor:pointer;{% unless item.available %} opacity:.5; cursor:not-allowed;{% endunless %}">{% if item.available %}{{ 'search_page.add_to_cart' | t }} 🛒{% else %}{{ 'search_page.sold_out' | t }}{% endif %}</button>
                </form>
                {% else %}
                <a href="{{ item.url }}" class="fss-add" style="margin-top:auto; display:block; text-align:center; background:#c6ff3a; color:#0b0b0c; border-radius:11px; padding:11px; font-family:'Archivo',sans-serif; font-weight:800; font-size:14px;">{{ 'search_page.view_product' | t }} →</a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
      <div class="fss-pg" style="display:flex; justify-content:center; align-items:center; gap:8px; flex-wrap:wrap; margin-top:30px; font-family:'Archivo',sans-serif; font-weight:800; font-variant-numeric:tabular-nums;">
        {% if paginate.previous %}<a href="{{ paginate.previous.url }}" style="background:#151517; border:1px solid #2a2a2e; border-radius:11px; padding:10px 16px; color:#f5f5f4;">← {{ 'search_page.pagination_previous' | t }}</a>{% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}<a href="{{ part.url }}" style="background:#151517; border:1px solid #2a2a2e; border-radius:11px; padding:10px 15px; min-width:42px; text-align:center; color:#f5f5f4;">{{ part.title }}</a>
          {% elsif part.title == paginate.current_page %}<span class="fss-pg-cur" style="background:#c6ff3a; border:1px solid #c6ff3a; border-radius:11px; padding:10px 15px; min-width:42px; text-align:center; color:#0b0b0c;">{{ part.title }}</span>
          {% else %}<span style="padding:10px 8px; color:#56565d;">{{ part.title }}</span>{% endif %}
        {% endfor %}
        {% if paginate.next %}<a href="{{ paginate.next.url }}" style="background:#151517; border:1px solid #2a2a2e; border-radius:11px; padding:10px 16px; color:#f5f5f4;">{{ 'search_page.pagination_next' | t }} →</a>{% endif %}
      </div>
      {% endif %}
      {% endpaginate %}

      {%- else -%}
      <!-- ============ NO RESULTS STATE ============ -->
      <div style="text-align:center; padding:60px 20px 40px;">
        <div style="font-size:56px; margin-bottom:14px; line-height:1;">🤷</div>
        <h1 class="fss-h" style="font-size:clamp(20px,3vw,26px); margin:0 0 10px; line-height:1.1;">{{ 'search_page.no_results_heading' | t: terms: search.terms }}</h1>
        <p style="font-size:15px; color:#a1a1aa; max-width:420px; margin:0 auto 26px; line-height:1.5;">{{ 'search_page.no_results_subtext' | t }}</p>
        <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center;">
          {% for term in trending %}
            {%- assign term_label = trending_labels[forloop.index0] -%}
            {% if forloop.index <= 2 %}
            <a href="{{ routes.search_url }}?q={{ term | url_encode }}&type=product" class="fss-hot" style="display:flex; align-items:center; gap:7px; background:rgba(255,46,110,.1); border:1px solid rgba(255,46,110,.35); color:#ff9cba; border-radius:999px; padding:9px 15px; font-weight:600; font-size:14px;">🔥 {{ term_label | t }}</a>
            {% else %}
            <a href="{{ routes.search_url }}?q={{ term | url_encode }}&type=product" class="fss-pill" style="display:flex; align-items:center; gap:7px; background:#151517; border:1px solid #2a2a2e; color:#d4d4db; border-radius:999px; padding:9px 15px; font-weight:600; font-size:14px;">{{ term_label | t }}</a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {%- endif -%}
    {%- endunless -%}

  </main>

  <!-- FOOTER (minimal centered) -->
  <footer style="border-top:1px solid #1d1d20; padding:28px clamp(16px,4vw,32px); position:relative; z-index:1; text-align:center; font-size:12px; color:#56565d;">
    <a href="{{ routes.root_url }}" class="fss-h" style="display:inline-block; font-size:20px; margin-bottom:8px; color:#f5f5f4;"><span style="color:#c6ff3a;">F</span>store<span style="color:#ff2e6e;">.</span></a>
    <div>© {{ 'now' | date: '%Y' }} {{ shop.name }} · {{ 'search_page.footer_tagline' | t }}</div>
  </footer>
</div>

<script>
(function(){
  var KEY='fss_recent';
  {% if search.performed and search.terms != blank %}
  try{
    var t={{ search.terms | json }};
    if(t && t.trim()){
      var arr=JSON.parse(localStorage.getItem(KEY)||'[]');
      arr=arr.filter(function(x){ return x.toLowerCase()!==t.toLowerCase(); });
      arr.unshift(t); arr=arr.slice(0,8);
      localStorage.setItem(KEY,JSON.stringify(arr));
    }
  }catch(e){}
  {% endif %}
  var wrap=document.getElementById('fssRecentWrap');
  if(wrap){
    try{
      var items=JSON.parse(localStorage.getItem(KEY)||'[]');
      if(items.length){
        var box=document.getElementById('fssRecentPills');
        var base={{ routes.search_url | json }};
        items.forEach(function(term){
          var a=document.createElement('a');
          a.href=base+'?q='+encodeURIComponent(term)+'&type=product';
          a.textContent='🕘 '+term;
          a.style.cssText='display:flex;align-items:center;gap:7px;background:#151517;border:1px solid #2a2a2e;color:#d4d4db;border-radius:999px;padding:9px 15px;font-weight:600;font-size:14px;text-decoration:none;';
          box.appendChild(a);
        });
        wrap.style.display='block';
        var clr=document.getElementById('fssRecentClear');
        if(clr) clr.addEventListener('click',function(){ localStorage.removeItem(KEY); wrap.style.display='none'; });
      }
    }catch(e){}
  }
})();
</script>
