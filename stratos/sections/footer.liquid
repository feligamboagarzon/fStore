<style>
  footer.site-footer {
    background-color: var(--color-dark);
    color: rgba(255,255,255,0.7);
    padding: var(--spacing-xxxl) 0 var(--spacing-xl);
    margin-top: auto;
  }
  .footer-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--spacing-lg);
    padding-bottom: var(--spacing-xxl);
    margin-bottom: var(--spacing-xxl);
    border-bottom: 1px solid var(--color-line-dark);
  }
  .footer-cta__title {
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-white);
    line-height: 1;
    max-width: 14ch;
  }
  .footer-cta__title em { font-style: normal; color: var(--color-accent); }

  .newsletter-form {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--color-line-dark);
    border-radius: var(--radius-full);
    padding: 6px 6px 6px var(--spacing-md);
    min-width: 300px;
    max-width: 420px;
    flex: 1;
  }
  .newsletter-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-size: 0.9rem;
    color: var(--color-white);
    font-family: inherit;
  }
  .newsletter-input::placeholder { color: rgba(255,255,255,0.45); }
  .newsletter-submit {
    flex-shrink: 0;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    border-radius: var(--radius-full);
    width: 42px; height: 42px;
    display: inline-flex; align-items: center; justify-content: center;
    transition: transform var(--transition-fast);
  }
  .newsletter-submit:hover { transform: scale(1.05); }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: var(--spacing-xl);
  }
  @media (max-width: 820px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--spacing-xl); } }
  @media (max-width: 480px) { .footer-grid { grid-template-columns: 1fr 1fr; } }

  .footer-brand__logo { height: 32px; width: auto; object-fit: contain; display: block; margin-bottom: var(--spacing-md); filter: brightness(0) invert(1); }
  .footer-brand__text { font-size: 0.875rem; line-height: 1.55; max-width: 30ch; }
  .footer-payment { display: flex; gap: 6px; flex-wrap: wrap; margin-top: var(--spacing-lg); }
  .footer-payment svg { width: 38px; height: 24px; border-radius: 4px; opacity: 0.9; }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    margin-bottom: var(--spacing-md);
  }
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: var(--spacing-sm); }
  .footer-links a { font-size: 0.9rem; color: rgba(255,255,255,0.7); transition: color var(--transition-fast); }
  .footer-links a:hover { color: var(--color-accent); }

  .footer-bottom {
    margin-top: var(--spacing-xxxl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-line-dark);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }
  .footer-brand { grid-column: span 1; }
  @media (max-width: 820px) { .footer-brand { grid-column: 1 / -1; } }
</style>

<footer class="site-footer">
  <div class="container">
    <div class="footer-cta">
      <h2 class="footer-cta__title">Join the <em>club</em>.</h2>
      <form class="newsletter-form" onsubmit="event.preventDefault(); this.reset(); this.querySelector('.newsletter-input').placeholder = 'You\'re in! 🎉';">
        <input type="email" placeholder="Email for early drops & deals" required class="newsletter-input">
        <button type="submit" class="newsletter-submit" aria-label="Subscribe">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" width="18" height="18">
            <path d="M3.333 10h13.334M11.667 5l5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>

    <div class="footer-grid">
      <div class="footer-brand">
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" width="140" height="32" class="footer-brand__logo">
        <p class="footer-brand__text">The internet's most viral products — curated, in stock, and shipped fast.</p>
        {% if section.settings.show_payment_icons %}
          <div class="footer-payment">
            {% for type in shop.enabled_payment_types %}
              {{ type | payment_type_svg_tag }}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="footer-column">
        <h3 class="footer-heading">Shop</h3>
        <ul class="footer-links">
          {% for link in section.settings.shop_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-column">
        <h3 class="footer-heading">Support</h3>
        <ul class="footer-links">
          {% for link in section.settings.support_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-column">
        <h3 class="footer-heading">Legal</h3>
        <ul class="footer-links">
          {% for link in section.settings.legal_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p>Fast shipping worldwide.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop Menu"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Support Menu"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal Menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
