<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: clamp(520px, 88vh, 900px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background-color: var(--color-dark);
  }
  .hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(12,12,14,0.15) 0%, rgba(12,12,14,0.20) 45%, rgba(12,12,14,0.82) 100%);
    z-index: 2;
  }
  .hero__content {
    position: relative;
    z-index: 10;
    color: var(--color-white);
    padding-bottom: var(--spacing-xxxl);
    padding-top: var(--spacing-xxxl);
    max-width: 760px;
  }
  .hero__eyebrow {
    color: rgba(255,255,255,0.85);
    margin-bottom: var(--spacing-lg);
  }
  .hero__eyebrow::before {
    box-shadow: 0 0 0 4px rgba(198, 255, 61, 0.25);
  }
  .hero__title {
    font-size: clamp(2.6rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin-bottom: var(--spacing-md);
  }
  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    max-width: 46ch;
    color: rgba(255,255,255,0.9);
    margin-bottom: var(--spacing-xl);
    line-height: 1.5;
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--spacing-md); align-items: center; }
  .hero__ghost {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.95rem 0.5rem;
    border-bottom: 1.5px solid rgba(255,255,255,0.4);
    border-radius: 0;
    transition: border-color var(--transition-fast);
  }
  .hero__ghost:hover { border-color: var(--color-accent); }

  @media (max-width: 600px) {
    .hero { min-height: 78vh; align-items: flex-end; }
    .hero__content { padding-bottom: var(--spacing-xxl); }
    .hero__actions .btn { flex: 1; }
  }
</style>

<div class="hero">
  {% if section.settings.video_url != blank %}
    <video class="hero__media" autoplay loop muted playsinline {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1200 }}"{% endif %}>
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {% elsif section.settings.image != blank %}
    <img class="hero__media" src="{{ section.settings.image | image_url: width: 2000 }}" alt="{{ section.settings.title | escape }}" width="2000" height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}">
  {% endif %}

  <div class="hero__overlay"></div>

  <div class="hero__content container">
    {% if section.settings.eyebrow != blank %}
      <span class="eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h1 class="hero__title">{{ section.settings.title }}</h1>
    <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    <div class="hero__actions">
      <a href="{{ section.settings.button_link }}" class="btn btn--accent">{{ section.settings.button_label }}</a>
      {% if section.settings.button_label_2 != blank %}
        <a href="{{ section.settings.button_link_2 }}" class="hero__ghost">
          {{ section.settings.button_label_2 }}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" width="16" height="16">
            <path d="M5 10h10M11 6l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Video",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Upload a video to files and paste the URL here."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback / poster image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Trending on your FYP"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The drops everyone's talking about."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "The internet's most viral products — hand-picked, in stock, and shipped fast."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary link label",
      "default": "See what's trending"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary link"
    }
  ],
  "presets": [
    {
      "name": "Hero Video"
    }
  ]
}
{% endschema %}
