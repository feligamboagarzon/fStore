<style>
  .trust-banner { padding: var(--spacing-xxl) 0; border-top: 1px solid var(--color-line); border-bottom: 1px solid var(--color-line); }
  .trust-banner__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }
  @media (min-width: 768px) {
    .trust-banner__inner { grid-template-columns: repeat(var(--trust-cols, 4), 1fr); gap: 0; }
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    text-align: left;
  }
  @media (min-width: 768px) {
    .trust-item { padding: 0 var(--spacing-xl); }
    .trust-item:not(:last-child) { border-right: 1px solid var(--color-line); }
    .trust-item:first-child { padding-left: 0; }
  }
  .trust-item__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-bg-subtle);
    color: var(--color-text);
  }
  .trust-item__icon svg { width: 22px; height: 22px; }
  .trust-item__title { font-family: var(--font-heading); font-weight: 600; font-size: 0.92rem; color: var(--color-text); margin-bottom: 2px; }
  .trust-item__text { font-size: 0.8rem; color: var(--color-muted); line-height: 1.35; }
</style>

<div class="trust-banner">
  <div class="container trust-banner__inner" style="--trust-cols: {{ section.blocks.size }};">
    {% for block in section.blocks %}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <div class="trust-item__icon">
          {% if block.settings.icon == 'shipping' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 3h15v13H1zM16 8h4l3 3v5h-7M5.5 21a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5zM18.5 21a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
            </svg>
          {% elsif block.settings.icon == 'support' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
            </svg>
          {% elsif block.settings.icon == 'guarantee' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <polyline points="9 11 11 13 15 9" />
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          {% endif %}
        </div>
        <div>
          <div class="trust-item__title">{{ block.settings.title }}</div>
          <div class="trust-item__text">{{ block.settings.text }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "support", "label": "Support" },
            { "value": "guarantee", "label": "Guarantee" },
            { "value": "star", "label": "Star" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "On all orders over $30"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Banner",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping", "title": "Free shipping", "text": "Worldwide over $30" } },
        { "type": "trust_item", "settings": { "icon": "guarantee", "title": "30-day returns", "text": "Not happy? Full refund." } },
        { "type": "trust_item", "settings": { "icon": "support", "title": "24/7 support", "text": "Real humans, always" } },
        { "type": "trust_item", "settings": { "icon": "star", "title": "50k+ happy fans", "text": "Rated 4.8 / 5" } }
      ]
    }
  ]
}
{% endschema %}
